@@ -1542,6 +1569,7 @@ ssize_t psock_tcp_send(FAR struct socket *psock, FAR const void *buf,
               /* A buffer allocation error occurred */
 
               nerr("ERROR: Failed to allocate write buffer\n");
+              g_tcp_sendbuffer_diag.wrbuffer_alloc_fail++;
 
               if (nonblock || timeout != UINT_MAX)
                 {
@@ -1628,6 +1656,7 @@ ssize_t psock_tcp_send(FAR struct socket *psock, FAR const void *buf,
