+/****************************************************************************
+ * Name: telnet_send_echo_state
+ ****************************************************************************/
+
+static void telnet_send_echo_state(FAR struct telnet_dev_s *priv)
+{
+  if ((priv->td_lflag & ECHO) != 0)
+    {
+      /* NuttX readline echoes normal interactive input.  Tell the Telnet
+       * client that the server will provide echo so clients do not get stuck
+       * in local line/echo behavior that differs from serial NSH.
+       */
+
+      telnet_sendopt(priv, TELNET_WILL, TELNET_ECHO);
+    }
+  else
+    {
+      /* Password prompts and other no-echo terminal modes clear ECHO. */
+
+      telnet_sendopt(priv, TELNET_WONT, TELNET_ECHO);
+    }
+}
