@@ -783,10 +784,26 @@ static void netdev_upper_work(FAR void *arg)
 {
   FAR struct netdev_upperhalf_s *upper = arg;
 
-  /* RX may release quota and driver buffer, so do RX first. */
+  /* User-space TCP sends can enqueue data while holding the connection/device
+   * lock and then wake this thread to perform the actual lower-half poll.
+   * Prioritize that explicit TX wake once so accepted TCP services do not
+   * leave banners or HTTP replies queued behind opportunistic RX polling.
+   */
 
-  netdev_upper_rxpoll_work(upper);
-  netdev_upper_txavail_work(upper);
+  if (upper->txrequested)
+    {
+      upper->txrequested = false;
+      netdev_upper_txavail_work(upper);
+      netdev_upper_rxpoll_work(upper);
+      netdev_upper_txavail_work(upper);
+    }
+  else
+    {
+      /* RX may release quota and driver buffer, so do RX first. */
+
+      netdev_upper_rxpoll_work(upper);
+      netdev_upper_txavail_work(upper);
+    }
 }
 
