diff --git a/boards/arm/rp23xx/common/src/rp23xx_spisd.c b/boards/arm/rp23xx/common/src/rp23xx_spisd.c
index 211ce5e224..83f76cf37d 100644
--- a/boards/arm/rp23xx/common/src/rp23xx_spisd.c
+++ b/boards/arm/rp23xx/common/src/rp23xx_spisd.c
@@ -24,11 +24,23 @@
 
 #include <nuttx/config.h>
 
+#ifdef CONFIG_RP23XX_SPISD_AUTOMOUNT
+#  include <errno.h>
+#  include <stdbool.h>
+#  include <stdio.h>
+#  include <sys/stat.h>
+#endif
+
 #include <nuttx/debug.h>
 #include <nuttx/mmcsd.h>
 #include <nuttx/board.h>
 #include <nuttx/fs/fs.h>
 
+#if defined(CONFIG_RP23XX_SPISD_AUTOMOUNT) && \
+    (defined(CONFIG_MBR_PARTITION) || defined(CONFIG_GPT_PARTITION))
+#  include <nuttx/fs/partition.h>
+#endif
+
 #include "rp23xx_spi.h"
 #include "rp23xx_gpio.h"
 
@@ -42,6 +54,152 @@
 #  define CONFIG_RP23XX_SPISD_SLOT_NO 0
 #endif
 
+#define RP23XX_SPISD_BLOCKDEV   "/dev/mmcsd0"
+#define RP23XX_SPISD_PARTDEV    "/dev/mmcsd0p0"
+#define RP23XX_SPISD_MOUNTPT    "/mnt/sd0"
+
+/****************************************************************************
+ * Private Functions
+ ****************************************************************************/
+
+#ifdef CONFIG_RP23XX_SPISD_AUTOMOUNT
+#if defined(CONFIG_MBR_PARTITION) || defined(CONFIG_GPT_PARTITION)
+static bool rp23xx_spisd_register_partitions(FAR int *parse_ret);
+#endif
+
+static int rp23xx_spisd_mkdir(FAR const char *path)
+{
+  int ret;
+
+  ret = mkdir(path, 0777);
+  if (ret < 0 && errno != EEXIST)
+    {
+      _err("ERROR: mkdir(%s) failed: %d\n", path, errno);
+      return -errno;
+    }
+
+  return OK;
+}
+
+static int rp23xx_spisd_mount(FAR const char *devpath)
+{
+  int ret;
+
+  ret = nx_mount(devpath, RP23XX_SPISD_MOUNTPT, "vfat", 0, NULL);
+  if (ret < 0 && ret != -EBUSY)
+    {
+      _err("ERROR: Failed to mount %s at %s: %d\n",
+           devpath, RP23XX_SPISD_MOUNTPT, ret);
+    }
+
+  return ret;
+}
+
+static int rp23xx_spisd_mediachange(void)
+{
+#ifndef CONFIG_SPI_CALLBACK
+  return -ENOSYS;
+#else
+#if CONFIG_RP23XX_SPISD_SPI_CH == 0
+#  ifdef CONFIG_RP23XX_SPI0
+  return rp23xx_spi0_mediachange();
+#  else
+  return -ENODEV;
+#  endif
+#elif CONFIG_RP23XX_SPISD_SPI_CH == 1
+#  ifdef CONFIG_RP23XX_SPI1
+  return rp23xx_spi1_mediachange();
+#  else
+  return -ENODEV;
+#  endif
+#else
+  return -ENODEV;
+#endif
+#endif
+}
+
+int board_spisd_mount(void)
+{
+  int ret;
+#if defined(CONFIG_MBR_PARTITION) || defined(CONFIG_GPT_PARTITION)
+  int parse_ret = OK;
+#endif
+
+  rp23xx_spisd_mkdir("/mnt");
+  rp23xx_spisd_mkdir(RP23XX_SPISD_MOUNTPT);
+
+  ret = rp23xx_spisd_mediachange();
+  if (ret < 0 && ret != -ENODEV)
+    {
+      _err("ERROR: Failed to rescan SPI SDCARD media: %d\n", ret);
+    }
+
+#if defined(CONFIG_MBR_PARTITION) || defined(CONFIG_GPT_PARTITION)
+  if (rp23xx_spisd_register_partitions(&parse_ret))
+    {
+      ret = rp23xx_spisd_mount(RP23XX_SPISD_PARTDEV);
+      return (ret >= 0 || ret == -EBUSY) ? OK : ret;
+    }
+
+  if (parse_ret < 0 && parse_ret != -EINVAL)
+    {
+      _err("ERROR: SDCARD partition probe failed: %d\n", parse_ret);
+      return parse_ret;
+    }
+#endif
+
+  ret = rp23xx_spisd_mount(RP23XX_SPISD_BLOCKDEV);
+  return (ret >= 0 || ret == -EBUSY) ? OK : ret;
+}
+
+#if defined(CONFIG_MBR_PARTITION) || defined(CONFIG_GPT_PARTITION)
+static void rp23xx_spisd_partition_handler(FAR struct partition_s *part,
+                                           FAR void *arg)
+{
+  FAR bool *registered = (FAR bool *)arg;
+  char devname[32];
+  int ret;
+
+  snprintf(devname, sizeof(devname), "/dev/mmcsd0p%zu", part->index);
+  ret = register_blockpartition(devname, 0660, RP23XX_SPISD_BLOCKDEV,
+                                part->firstblock, part->nblocks);
+  if (ret >= 0 || ret == -EEXIST)
+    {
+      _info("Registered SD partition %s (start=%lu nblocks=%lu)\n",
+            devname, (unsigned long)part->firstblock,
+            (unsigned long)part->nblocks);
+      *registered = true;
+    }
+  else
+    {
+      _err("ERROR: Failed to register SD partition %s: %d\n",
+           devname, ret);
+    }
+}
+
+static bool rp23xx_spisd_register_partitions(FAR int *parse_ret)
+{
+  bool registered = false;
+  int ret;
+
+  ret = parse_block_partition(RP23XX_SPISD_BLOCKDEV,
+                              rp23xx_spisd_partition_handler,
+                              &registered);
+  if (parse_ret != NULL)
+    {
+      *parse_ret = ret;
+    }
+
+  if (ret < 0)
+    {
+      _err("ERROR: Failed to parse SD partition table: %d\n", ret);
+    }
+
+  return registered;
+}
+#endif
+#endif
+
 /****************************************************************************
  * Public Functions
  ****************************************************************************/
@@ -98,11 +256,16 @@ int board_spisd_initialize(int minor, int bus)
 
   /* Mount filesystem */
 
-  ret = nx_mount("/dev/mmcsd0", "/mnt/sd0", "vfat", 0, NULL);
+#ifdef CONFIG_RP23XX_SPISD_AUTOMOUNT
+  ret = board_spisd_mount();
   if (ret < 0)
     {
-      _err("ERROR: Failed to mount the SDCARD. %d\n", ret);
+      _err("ERROR: SPI SDCARD is not mounted; persistence will be "
+           "unavailable: %d\n", ret);
     }
+#else
+  _info("SPI SDCARD block device ready; automount disabled\n");
+#endif
 
   return OK;
 }
