+                        XBOX_BUTTON_DPAD_RIGHT_INDEX,
+                        XBOX_BUTTON_DPAD_RIGHT_MASK);
+      rpt.bumper_left =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_BUMPER_LEFT_INDEX,
+                        XBOX_BUTTON_BUMPER_LEFT_MASK);
+      rpt.bumper_right =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_BUMPER_RIGHT_INDEX,
+                        XBOX_BUTTON_BUMPER_RIGHT_MASK);
+      rpt.stick_click_left =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_STICK_LEFT_INDEX,
+                        XBOX_BUTTON_STICK_LEFT_MASK);
+      rpt.stick_click_right =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_STICK_RIGHT_INDEX,
+                        XBOX_BUTTON_STICK_RIGHT_MASK);
+
+      rpt.trigger_left = usbhost_getle16s(&priv->tbuffer[6]);
+      rpt.trigger_right = usbhost_getle16s(&priv->tbuffer[8]);
+      rpt.stick_left_x = usbhost_getle16s(&priv->tbuffer[10]);
+      rpt.stick_left_y = usbhost_getle16s(&priv->tbuffer[12]);
+      rpt.stick_right_x = usbhost_getle16s(&priv->tbuffer[14]);
+      rpt.stick_right_y = usbhost_getle16s(&priv->tbuffer[16]);
+
+      return usbhost_publish(priv, &rpt);
+
+    default:
+      uinfo("Received Xbox One message type: %x\n", priv->tbuffer[0]);
+      break;
+    }
+
+  return OK;
+}
