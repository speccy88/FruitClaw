+/****************************************************************************
+ * Name: usbhost_parse_xboxone
+ *
+ * Description:
+ *   Parse Xbox One/Series GIP reports.  This preserves the original driver
+ *   initialization, guide-button ACK, and input packet behavior.
+ *
+ ****************************************************************************/
+
+static int usbhost_parse_xboxone(FAR struct usbhost_state_s *priv,
+                                 ssize_t nbytes)
+{
+  FAR struct usbhost_hubport_s *hport = priv->usbclass.hport;
+  struct xbox_controller_buttonstate_s rpt;
+  uint8_t seq_num;
+  int ret;
+
+  switch (priv->tbuffer[0])
+    {
+    case USBHOST_WAITING_CONNECTION:
+      /* Send the initialization message when we receive the first waiting
+       * connection message.
+       */
+
+      if (!priv->initialized)
+        {
+          ret = nxmutex_lock(&priv->lock);
+          if (ret < 0)
+            {
+              return ret;
+            }
+
+          priv->tbuffer[0] = 0x05;
+          priv->tbuffer[1] = 0x20;
+          priv->tbuffer[2] = priv->out_seq_num++;
+          priv->tbuffer[3] = 0x01;
+          priv->tbuffer[4] = 0x00;
+          DRVR_TRANSFER(hport->drvr, priv->epout, priv->tbuffer, 5);
+          priv->initialized = true;
+
+          nxmutex_unlock(&priv->lock);
+        }
+
+      break;
+
+    case USBHOST_GUIDE_BUTTON_STATUS:
+      if (nbytes <= XBOX_BUTTON_GUIDE_INDEX)
+        {
+          uerr("ERROR: Short guide status report: %d\n", (int)nbytes);
+          break;
+        }
+
+      ret = nxmutex_lock(&priv->lock);
+      if (ret < 0)
+        {
+          return ret;
+        }
+
+      priv->rpt.guide =
+        (priv->tbuffer[XBOX_BUTTON_GUIDE_INDEX] != 0) ? true : false;
+      priv->valid = true;
+
+      /* The One X controller requires an ACK of the guide button status
+       * message.
+       */
+
+      if (priv->tbuffer[1] == 0x30)
+        {
+          static const uint8_t guide_button_report_ack[] =
+          {
