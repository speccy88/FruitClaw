+/****************************************************************************
+ * Name: usbhost_xbox360w_inquire
+ *
+ * Description:
+ *   Ask an Xbox 360 wireless receiver slot whether a controller is present.
+ *   The command is from the MIT-licensed TinyUSB XInput host reference used
+ *   by wili8jam.
+ *
+ ****************************************************************************/
+
+static ssize_t usbhost_xbox360w_inquire(FAR struct usbhost_state_s *priv,
+                                        uint8_t slotno)
+{
+  FAR struct usbhost_hubport_s *hport = priv->usbclass.hport;
+  uint8_t xbox360w_inquire_present[] =
+  {
+    0x08, 0x00, 0x0f, 0xc0
+  };
+
+  DEBUGASSERT(slotno < priv->nslots);
+  return DRVR_TRANSFER(hport->drvr, priv->slots[slotno].epout,
+                       xbox360w_inquire_present,
+                       sizeof(xbox360w_inquire_present));
+}
