+} pio_port_t;
+
+//--------------------------------------------------------------------+
+//
+//--------------------------------------------------------------------+
+
+enum {
+  PIO_USB_MODE_INVALID = 0,
+  PIO_USB_MODE_DEVICE,
+  PIO_USB_MODE_HOST,
+};
