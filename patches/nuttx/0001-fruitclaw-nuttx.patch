+static bool rp23xx_spisd_register_partitions(FAR int *parse_ret)
+{
+  bool registered = false;
+  int ret;
+
+  ret = parse_block_partition(RP23XX_SPISD_BLOCKDEV,
+                              rp23xx_spisd_partition_handler,
+                              &registered);
+  if (parse_ret != NULL)
+    {
+      *parse_ret = ret;
+    }
+
+  if (ret < 0)
+    {
+      _err("ERROR: Failed to parse SD partition table: %d\n", ret);
+    }
+
+  return registered;
+}
+#endif
+#endif
