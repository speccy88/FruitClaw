+
+  info->ll_last_tx_len = pio_usb_debug.last_tx_len;
+  info->ll_last_tx_wait_stage = pio_usb_debug.last_tx_wait_stage;
+  info->ll_tx_timeout_count = pio_usb_debug.tx_timeout_count;
