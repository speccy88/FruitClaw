+/* Live hub instances.  Used by board bring-up tools to force a port poll
+ * when a hub interrupt change notification was missed.
+ */
+
+static FAR struct usbhost_hubclass_s *g_hub_instances;
+
 /****************************************************************************
  * Private Functions
