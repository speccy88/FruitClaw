+static void esp_hosted_schedule_rx_work_delay(
+  FAR struct esp_hosted_driver_s *priv, clock_t delay)
+{
+  int ret;
+
+  if (work_available(&priv->rx_work))
+    {
+      ret = work_queue(ESP_HOSTED_WORK_QUEUE, &priv->rx_work,
+                       esp_hosted_rx_work, priv, delay);
+      if (ret >= 0)
+        {
+          priv->stats.rx_work_count++;
+        }
+    }
+}
+
+static void esp_hosted_schedule_rx_work(FAR struct esp_hosted_driver_s *priv)
+{
+  esp_hosted_schedule_rx_work_delay(priv, 0);
+}
