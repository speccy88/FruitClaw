+
+#define DMA_CMD_BUF_WORDS                (((V_TOTAL_LINES - \
+                                          RP23XX_DVI_CONTENT_LINES) * \
+                                          DMA_CMD_BLOCK_WORDS) + \
+                                          (RP23XX_DVI_CONTENT_LINES * \
