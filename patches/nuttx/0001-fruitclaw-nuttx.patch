+/****************************************************************************
+ * Name: usbhost_freeendpoints
+ *
+ * Description:
+ *   Free all interrupt endpoints allocated by this class instance.
+ *
+ ****************************************************************************/
+
+static void usbhost_freeendpoints(FAR struct usbhost_state_s *priv)
+{
+  FAR struct usbhost_hubport_s *hport;
+  int i;
+
+  DEBUGASSERT(priv != NULL && priv->usbclass.hport != NULL);
+  hport = priv->usbclass.hport;
+
+  for (i = 0; i < priv->nslots; i++)
+    {
+      if (priv->slots[i].epin)
+        {
+          DRVR_EPFREE(hport->drvr, priv->slots[i].epin);
+          priv->slots[i].epin = NULL;
+        }
+
+      if (priv->slots[i].epout)
+        {
+          DRVR_EPFREE(hport->drvr, priv->slots[i].epout);
+          priv->slots[i].epout = NULL;
+        }
+
+      priv->slots[i].active = false;
+    }
+
+  priv->epin = NULL;
+  priv->epout = NULL;
+  priv->nslots = 0;
+}
