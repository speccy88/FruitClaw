+
+  rp23xx_spisd_mkdir("/mnt");
+  rp23xx_spisd_mkdir(RP23XX_SPISD_MOUNTPT);
+
+  ret = rp23xx_spisd_mediachange();
+  if (ret < 0 && ret != -ENODEV)
+    {
+      _err("ERROR: Failed to rescan SPI SDCARD media: %d\n", ret);
+    }
+
+#if defined(CONFIG_MBR_PARTITION) || defined(CONFIG_GPT_PARTITION)
+  if (rp23xx_spisd_register_partitions(&parse_ret))
+    {
+      ret = rp23xx_spisd_mount(RP23XX_SPISD_PARTDEV);
+      return (ret >= 0 || ret == -EBUSY) ? OK : ret;
+    }
+
+  if (parse_ret < 0 && parse_ret != -EINVAL)
+    {
+      _err("ERROR: SDCARD partition probe failed: %d\n", parse_ret);
+      return parse_ret;
