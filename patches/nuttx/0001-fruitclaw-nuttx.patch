+void board_fruitjam_bootguard_disarm(void);
+#endif
+
+#ifdef CONFIG_ADAFRUIT_FRUIT_JAM_RP2350_ESP_HOSTED
+int board_fruitjam_esp_hosted_start(void);
+int board_fruitjam_shared_reset_recover(void);
+#endif
+
