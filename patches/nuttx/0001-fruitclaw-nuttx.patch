+static inline void pio_calculate_clkdiv_from_float(float div,
+                                                   uint16_t *div_int,
+                                                   uint8_t *div_frac)
+{
+  uint32_t div256;
+
+  if (div < 1.0f)
+    {
+      div = 1.0f;
+    }
+
+  div256 = (uint32_t)(div * 256.0f + 0.5f);
+  if (div256 < 256)
+    {
+      div256 = 256;
+    }
+
+  *div_int = div256 >> 8;
+  *div_frac = div256 & 0xff;
+}
