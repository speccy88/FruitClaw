+#define RP23XX_DVI_NO_PENDING_BUFFER     UINT32_MAX
+#define RP23XX_DVI_TIMERAWL              (RP23XX_TIMER0_BASE + 0x28)
+#ifdef CONFIG_SCHED_LPWORK
