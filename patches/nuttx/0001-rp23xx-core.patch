+/****************************************************************************
+ * Name: i2s_dma_timeout
+ *
+ * Description:
+ *   Convert an upper-layer timeout of zero into a bounded DMA timeout.
+ *
+ ****************************************************************************/
+
+static uint32_t i2s_dma_timeout(struct rp23xx_i2s_s *priv,
+                                struct ap_buffer_s *apb,
+                                uint32_t timeout)
+{
+  uint64_t nbytes;
+  uint64_t bytes_per_second;
+  uint64_t timeout_ms;
+
+  if (timeout > 0)
+    {
+      return timeout;
+    }
+
+  if (priv->samplerate == 0 || priv->channels == 0 || priv->datalen == 0)
+    {
+      return MSEC2TICK(RP23XX_I2S_TIMEOUT_MARGIN_MS);
+    }
+
+  nbytes = apb->nbytes - apb->curbyte;
+  bytes_per_second = ((uint64_t)priv->samplerate * priv->channels *
+                      priv->datalen) / 8;
+  if (bytes_per_second == 0)
+    {
+      return MSEC2TICK(RP23XX_I2S_TIMEOUT_MARGIN_MS);
+    }
+
+  timeout_ms = (nbytes * MSEC_PER_SEC + bytes_per_second - 1) /
+               bytes_per_second;
+  timeout_ms += RP23XX_I2S_TIMEOUT_MARGIN_MS;
+  if (timeout_ms > 5000)
+    {
+      timeout_ms = 5000;
+    }
+
+  return MSEC2TICK((uint32_t)timeout_ms);
+}
