diff --git a/arch/arm/src/rp23xx/Kconfig b/arch/arm/src/rp23xx/Kconfig
index cbeba7bbaa..044d7d77f2 100644
--- a/arch/arm/src/rp23xx/Kconfig
+++ b/arch/arm/src/rp23xx/Kconfig
@@ -14,6 +14,27 @@ config RP23XX_DMAC
 	default y
 	select ARCH_DMA
 
+config RP23XX_HSTX_DVI_SCANOUT_PSRAM
+	bool "Allocate HSTX DVI scanout buffers from PSRAM"
+	default n
+	depends on RP23XX_HSTX_DVI
+	depends on RP23XX_PSRAM_HEAP_USER
+	---help---
+		Allocate the double-buffered HSTX DVI scanout frames from the
+		PSRAM-backed user heap instead of the internal kernel heap.  This
+		saves roughly two RGB565 frame buffers of internal SRAM on Fruit Jam
+		at the cost of DMA scanout traffic reading from external PSRAM.
+
+config RP23XX_HSTX_DVI_SINGLE_SCANOUT_INTERNAL
+	bool "Use one internal SRAM HSTX DVI scanout buffer"
+	default n
+	depends on RP23XX_HSTX_DVI
+	---help---
+		Use one internal SRAM scanout frame instead of double-buffered
+		scanout. This is intended for static display profiles such as
+		TRMNL, where /dev/fb0 changes infrequently and stable scanout
+		timing matters more than tear-free animation.
+
 config RP23XX_SYSTIMER_SYSTICK
 	bool "SysTick System Timer"
 	default n
@@ -23,6 +44,70 @@ config RP23XX_SYSTIMER_SYSTICK
 	---help---
 		Use ARM SysTick.
 
+config RP23XX_PSRAM
+	bool "External PSRAM"
+	default n
+	---help---
+		Enable the RP2350 QMI CS1 external PSRAM interface.
+
+if RP23XX_PSRAM
+
+choice
+	prompt "PSRAM heap mode"
+	default RP23XX_PSRAM_HEAP_USER if MM_KERNEL_HEAP
+	default RP23XX_PSRAM_HEAP_SINGLE
+
+config RP23XX_PSRAM_HEAP_SINGLE
+	bool "Add PSRAM to the main heap"
+	depends on MM_REGIONS > 1
+	depends on !MM_KERNEL_HEAP
+	---help---
+		Add PSRAM as an extra region in the default user heap.
+
+config RP23XX_PSRAM_HEAP_USER
+	bool "Use PSRAM as the user heap"
+	depends on MM_KERNEL_HEAP
+	---help---
+		Use internal SRAM for the kernel heap and PSRAM for the default
+		user heap.
+
+config RP23XX_PSRAM_HEAP_SEPARATE
+	bool "Create a separate PSRAM heap"
+	select ARCH_HAVE_EXTRA_HEAPS
+	---help---
+		Create a separately named heap backed by PSRAM.
+
+endchoice
+
+config RP23XX_PSRAM_SIZE
+	int "PSRAM size in bytes"
+	default 8388608
+	---help---
+		Size of the external PSRAM aperture made available to NuttX.
+
+config RP23XX_PSRAM_MAX_SCK_HZ
+	int "Maximum PSRAM SCK frequency"
+	default 63000000
+	---help---
+		Maximum QMI SCK frequency used for PSRAM transfers.
+
+config RP23XX_PSRAM_WAIT_TIMEOUT
+	int "PSRAM QMI wait timeout"
+	default 1000000
+	---help---
+		Maximum poll iterations for QMI direct-mode wait loops during
+		PSRAM setup.
+
+config RP23XX_PSRAM_FALLBACK_KERNEL_HEAPSIZE
+	int "Fallback internal kernel heap size"
+	default 262144
+	depends on RP23XX_PSRAM_HEAP_USER
+	---help---
+		Internal SRAM reserved for the kernel heap if PSRAM detection
+		fails and the board must fall back to an internal user heap.
+
+endif # RP23XX_PSRAM
+
 #####################################################################
 #  UART Configuration
 #####################################################################
@@ -710,6 +795,307 @@ config RP23XX_I2S_PIO_SM
 
 endif # RP23XX_I2S
 
+#####################################################################
+#  PIO USB Host Configuration
+#####################################################################
+
+config RP23XX_PIO_USBHOST
+	bool "PIO USB host controller"
+	depends on USBHOST
+	depends on RP23XX_DMAC
+	select USBHOST_HAVE_ASYNCH
+	---help---
+		Enable a low/full-speed USB host controller implemented with
+		RP23XX PIO and one DMA channel. This is intended for boards such
+		as the Adafruit Fruit Jam that expose a PIO-USB host port.
+
+if RP23XX_PIO_USBHOST
+
+config RP23XX_PIO_USBHOST_AUTOSTART
+	bool "Start PIO USB host during board bring-up"
+	default n
+	---help---
+		Start the PIO USB host controller and USB host waiter from board
+		bring-up. Leave this disabled during bring-up so CDC/NSH can come
+		up first, then start the host explicitly with piousbhost.
+
+config RP23XX_PIO_USBHOST_DP_GPIO
+	int "PIO USB host D+ GPIO"
+	default 1
+	range 0 47
+
+config RP23XX_PIO_USBHOST_DM_GPIO
+	int "PIO USB host D- GPIO"
+	default 2
+	range 0 47
+
+config RP23XX_PIO_USBHOST_VBUS_GPIO
+	int "PIO USB host VBUS enable GPIO"
+	default -1
+	range -1 47
+	---help---
+		Set to -1 if the board does not expose a software-controlled
+		VBUS power switch.
+
+config RP23XX_PIO_USBHOST_VBUS_OFF_MS
+	int "VBUS power-cycle off time"
+	default 100
+	range 0 2000
+	depends on RP23XX_PIO_USBHOST_VBUS_GPIO >= 0
+	---help---
+		Time to hold the host-port VBUS switch off during explicit host
+		start. Some hubs and composite HID devices need a real discharge
+		window before they respond reliably after repeated firmware tests.
+
+config RP23XX_PIO_USBHOST_VBUS_ON_MS
+	int "VBUS power-on settle time"
+	default 250
+	range 0 3000
+	depends on RP23XX_PIO_USBHOST_VBUS_GPIO >= 0
+	---help---
+		Time to wait after enabling VBUS before starting the PIO USB host.
+
+config RP23XX_PIO_USBHOST_PIO
+	int "PIO instance"
+	default 0
+	range 0 2
+
+config RP23XX_PIO_USBHOST_TX_SM
+	int "TX state machine"
+	default 0
+	range 0 3
+
+config RP23XX_PIO_USBHOST_RX_SM
+	int "RX state machine"
+	default 1
+	range 0 3
+
+config RP23XX_PIO_USBHOST_EOP_SM
+	int "EOP state machine"
+	default 2
+	range 0 3
+
+config RP23XX_PIO_USBHOST_DMA_CHANNEL
+	int "Compatibility DMA channel id"
+	default 9
+	range 0 15
+	---help---
+		Pico-PIO-USB stores a DMA channel id in its transport state. The
+		NuttX port allocates a real DMA channel through rp23xx_dmachannel()
+		and uses this value only as the compatibility handle.
+
+config RP23XX_PIO_USBHOST_FRAME_IRQ
+	bool "Run frame pump from the timer interrupt"
+	default n
+	---help---
+		Run Pico-PIO-USB's 1 ms host frame pump directly from the TIMER0
+		alarm ISR. This matches the Pico SDK/TinyUSB host cadence more
+		closely and removes scheduler jitter from SOF and control-transfer
+		timing during Fruit Jam hub bring-up.
+
+config RP23XX_PIO_USBHOST_FRAME_PRIO
+	int "Frame pump thread priority"
+	default 90
+	depends on !RP23XX_PIO_USBHOST_FRAME_IRQ
+	---help---
+		Priority for the thread that runs Pico-PIO-USB's 1 ms host frame
+		pump. Keep this below the CDC/NSH recovery path while bringing up
+		keyboard and mouse enumeration.
+
+config RP23XX_PIO_USBHOST_FRAME_STACKSIZE
+	int "Frame pump thread stack size"
+	default 2048
+	depends on !RP23XX_PIO_USBHOST_FRAME_IRQ
+	---help---
+		Stack size for the PIO USB host frame pump thread.
+
+config RP23XX_PIO_USBHOST_TIMER_ALARM
+	int "TIMER0 alarm used for USB SOF"
+	default 3
+	range 0 3
+
+config RP23XX_PIO_USBHOST_DESCSIZE
+	int "Descriptor buffer size"
+	default 128
+	range 64 512
+
+config RP23XX_PIO_USBHOST_FIRST_ADDRESS
+	int "First USB device address"
+	default 1
+	range 1 127
+	---help---
+		First device address allocated by the PIO USB host root port.
+		Most controllers start at address 1. Some hub-focused bring-up
+		configurations may reserve lower addresses to match a known-good
+		stack while debugging hub enumeration timing.
+
+config RP23XX_PIO_USBHOST_XFER_TIMEOUT_MS
+	int "Synchronous transfer timeout in milliseconds"
+	default 5000
+	range 100 30000
+
+config RP23XX_PIO_USBHOST_ENUM_DELAY_MS
+	int "Root-port settle delay before reset"
+	default 100
+	range 50 1000
+
+config RP23XX_PIO_USBHOST_RESET_MS
+	int "Root-port reset duration"
+	default 20
+	range 10 100
+
+config RP23XX_PIO_USBHOST_POST_RESET_MS
+	int "Root-port post-reset settle delay"
+	default 50
+	range 10 500
+
+config RP23XX_PIO_USBHOST_SETADDR_DELAY_MS
+	int "Post SET_ADDRESS settle delay"
+	default 10
+	range 2 1000
+	---help---
+		Additional delay after the control status stage of SET_ADDRESS.
+		The common USB host enumerator already waits for the USB-specified
+		minimum. The PIO host can need a little extra guard time before the
+		next setup packet is sent to the new address.
+
+config RP23XX_PIO_USBHOST_ENUM_ATTEMPTS
+	int "Root-port enumeration attempts"
+	default 3
+	range 1 8
+	---help---
+		Number of clean root-port reset/enumeration attempts before the
+		PIO USB host reports the root device as failed. Each attempt closes
+		stale PIO endpoint state and re-enumerates from address zero.
+
+config RP23XX_PIO_USBHOST_CTRL_GAP_MS
+	int "Inter-control-transfer gap"
+	default 1
+	range 0 50
+	---help---
+		Small delay after a completed control transfer, and between setup
+		retries. This gives slow hubs and composite HID devices a little
+		breathing room without changing the USB host class logic.
+
+config RP23XX_PIO_USBHOST_CTRL_RETRIES
+	int "Setup-phase control retries"
+	default 2
+	range 0 8
+	---help---
+		Number of extra attempts for control transfers that fail before
+		the SETUP packet is ACKed. The retry is restricted to setup-phase
+		failures so side-effecting requests are not repeated after the
+		device has already accepted them.
+
+endif # RP23XX_PIO_USBHOST
+
+#####################################################################
+#  HSTX DVI Configuration
+#####################################################################
+
+config RP23XX_HSTX_DVI
+	bool "HSTX DVI framebuffer"
+	depends on RP23XX_RP2350B
+	select DRIVERS_VIDEO
+	select FB_UPDATE
+	select VIDEO_FB
+	select RP23XX_DMAC
+	---help---
+		Enable a DVI signal using the RP2350 HSTX block and expose it as
+		/dev/fb0.
+
+if RP23XX_HSTX_DVI
+
+choice RP23XX_HSTX_DVI_FB_PROFILE
+	prompt "HSTX DVI framebuffer profile"
+	default RP23XX_HSTX_DVI_FB_RGB565_320X240
+
+config RP23XX_HSTX_DVI_FB_RGB565_320X240
+	bool "320x240 RGB565, scaled for the current LVGL display path"
+	---help---
+		Expose /dev/fb0 as a 320x240 RGB565 framebuffer. With output
+		scaling set to 2, this fills the normal 640x480 DVI scanout and
+		matches the current Fruit Jam LVGL-friendly profile.
+
+config RP23XX_HSTX_DVI_FB_Y2_800X480
+	bool "800x480 Y2 grayscale, experimental TRMNL-style framebuffer"
+	depends on RP23XX_HSTX_DVI_SCANOUT_PSRAM || RP23XX_HSTX_DVI_SINGLE_SCANOUT_INTERNAL
+	---help---
+		Expose /dev/fb0 as an 800x480 2-bit uncompressed grayscale
+		framebuffer. The app-visible framebuffer is packed Y2, while the
+		driver expands it to compact RGB332 scanout buffers for HSTX DVI
+		output.
+
+		This profile is intended for future TRMNL-style work and is not
+		the LVGL RGB565 profile. It needs PSRAM-backed scanout buffers
+		because the internal scanout frames are still much larger than the
+		packed Y2 app-visible framebuffer.
+
+endchoice # RP23XX_HSTX_DVI_FB_PROFILE
+
+choice RP23XX_HSTX_DVI_Y2_OUTPUT_TIMING
+	prompt "800x480 Y2 DVI output timing"
+	depends on RP23XX_HSTX_DVI_FB_Y2_800X480
+	default RP23XX_HSTX_DVI_Y2_OUTPUT_VGA_640X480
+
+config RP23XX_HSTX_DVI_Y2_OUTPUT_VGA_640X480
+	bool "640x480 VGA timing with downsampled 800x480 Y2 scanout"
+	---help---
+		Keep /dev/fb0 as an 800x480 FB_FMT_Y2 framebuffer, but
+		downsample the expanded scanout horizontally into a 640x480
+		25.2 MHz DVI signal. This is the most compatible mode for
+		ordinary HDMI monitors during TRMNL bring-up.
+
+config RP23XX_HSTX_DVI_Y2_OUTPUT_NATIVE_800X480
+	bool "Native tight 800x480 timing"
+	---help---
+		Keep both /dev/fb0 and the DVI active timing at 800x480.
+		This is the pixel-preserving TRMNL-size timing validated on the
+		Fruit Jam bring-up monitor at 25.2 MHz, with 840x500 total timing.
+
+endchoice # RP23XX_HSTX_DVI_Y2_OUTPUT_TIMING
+
+config RP23XX_HSTX_DVI_OUTPUT_SCALING
+	int "HSTX DVI framebuffer output scaling"
+	depends on RP23XX_HSTX_DVI_FB_RGB565_320X240
+	default 2
+	range 1 2
+	---help---
+		Scale the 320x240 RGB565 framebuffer into the 640x480 active
+		DVI area. 2 fills the active area. 1 centers the framebuffer
+		with black borders and is useful as a low-bandwidth diagnostic.
+
+config RP23XX_HSTX_DVI_PIXEL_CLOCK
+	int "HSTX DVI target pixel clock"
+	default 25200000 if RP23XX_HSTX_DVI_Y2_OUTPUT_NATIVE_800X480
+	default 25200000 if RP23XX_HSTX_DVI_Y2_OUTPUT_VGA_640X480
+	default 25200000
+	range 1 126000000
+	---help---
+		Target pixel clock for the selected DVI profile. The actual pixel
+		clock is BOARD_HSTX_FREQ divided by the nearest integer divider.
+		The default 320x240/RGB565 profile uses 25.2 MHz. The native
+		800x480/Y2 TRMNL profile also uses 25.2 MHz, which divides evenly
+		from the Fruit Jam 126 MHz HSTX clock.
+
+config RP23XX_HSTX_DVI_BLACKOUT
+	bool "HSTX DVI black-only diagnostic scanout"
+	default n
+	---help---
+		Only stream legal black DVI timing over HSTX. The framebuffer device
+		still exists and can be filled, but scanout does not DMA framebuffer
+		pixels. This isolates HSTX timing/control DMA from framebuffer DMA.
+
+config RP23XX_HSTX_DVI_BOOT_AUTOSTART
+	bool "Start HSTX DVI from the board boot script"
+	default n
+	---help---
+		Start the DVI stream during board boot when the board rcS supports it.
+		This is useful for display-focused profiles that should present an
+		HDMI/DVI signal after reset without requiring a serial dvictrl start.
+
+endif # RP23XX_HSTX_DVI
+
 #####################################################################
 #  SPISD Configuration
 #####################################################################
@@ -734,6 +1120,14 @@ config RP23XX_SPISD_SPI_CH
 	---help---
 		Select spi channel number to use spi sd card.
 
+config RP23XX_SPISD_AUTOMOUNT
+	bool "Auto-mount SPI SD card at /mnt/sd0"
+	default y
+	---help---
+		Mount the SPI SD card during board bring-up. Disable this for
+		profiles that need to defer SD probing until after boot guards and
+		critical services are running.
+
 endif # SPISD Configuration
 
 #####################################################################
