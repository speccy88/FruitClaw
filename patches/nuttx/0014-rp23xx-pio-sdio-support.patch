diff --git a/arch/arm/src/rp23xx/rp23xx_pio.h b/arch/arm/src/rp23xx/rp23xx_pio.h
--- a/arch/arm/src/rp23xx/rp23xx_pio.h
+++ b/arch/arm/src/rp23xx/rp23xx_pio.h
@@ -2013,7 +2013,7 @@ int rp23xx_pio_claim_unused_sm(uint32_t pio, bool required);
  * Input Parameters:
  *   pio - PIO index (0..2)
- *   pin - GPIO pin number (0-29)
- *   bypass - bypass set true to bypass the synchronizer.
+ *   pin - Raw system GPIO pin number
+ *   bypass - Set true to bypass the synchronizer.
  *
  ****************************************************************************/
 
@@ -2022,10 +2022,13 @@ static inline void rp23xx_pio_set_input_sync_bypass(uint32_t pio,
                                                     uint32_t pin,
                                                     bool bypass)
 {
+  uint32_t virtual_pin;
+
   DEBUGASSERT(pin < RP23XX_GPIO_NUM);
+  virtual_pin = rp23xx_pio_gpio_to_pin(pio, pin);
 
-  modbits_reg32(bypass ? (1 << pin) : 0,
-                (1 << pin),
+  modbits_reg32(bypass ? (1u << virtual_pin) : 0,
+                (1u << virtual_pin),
                 RP23XX_PIO_INPUT_SYNC_BYPASS(pio));
 }
 
