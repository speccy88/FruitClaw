   while ((conn = tcp_nextconn(conn)) != NULL)
     {
+#ifdef CONFIG_NET_SOCKOPTS
+      /* SO_REUSEADDR permits a new listener to share its local endpoint
+       * with accepted connections inherited from the previous listener.
+       * The listener table is still checked below, so this does not provide
+       * SO_REUSEPORT semantics or permit two live listeners.
+       */
+
+      if (reuseaddr &&
+          _SO_GETOPT(conn->sconn.s_options, SO_REUSEADDR))
+        {
+          continue;
+        }
+#else
+      UNUSED(reuseaddr);
+#endif
+
       /* Check if this connection is open and the local port assignment
        * matches the requested port number.
        */
@@ -151,6 +168,19 @@
 }
 
 /****************************************************************************
+ * Name: tcp_reuseaddr
+ ****************************************************************************/
+
+static inline bool tcp_reuseaddr(FAR struct tcp_conn_s *conn)
+{
+#ifdef CONFIG_NET_SOCKOPTS
+  return _SO_GETOPT(conn->sconn.s_options, SO_REUSEADDR);
+#else
+  return false;
+#endif
+}
