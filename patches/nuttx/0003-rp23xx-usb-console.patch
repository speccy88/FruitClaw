+/****************************************************************************
+ * Name: usbhost_360w_any_connected
+ *
+ * Description:
+ *   Return true if any wireless receiver slot currently has a pad connected.
+ *
+ ****************************************************************************/
+
+static bool usbhost_360w_any_connected(FAR struct usbhost_state_s *priv)
+{
+  int i;
+
+  for (i = 0; i < priv->nslots; i++)
+    {
+      if (priv->slots[i].connected)
+        {
+          return true;
+        }
+    }
+
+  return false;
+}
