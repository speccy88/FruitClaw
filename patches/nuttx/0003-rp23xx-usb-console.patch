+/****************************************************************************
+ * Name: usbhost_xbox360w_inquire
+ *
+ * Description:
+ *   Ask an Xbox 360 wireless receiver slot whether a controller is present.
+ *   The command is from the MIT-licensed TinyUSB XInput host reference used
+ *   by wili8jam.
+ *
+ ****************************************************************************/
+
+static ssize_t usbhost_xbox360w_inquire(FAR struct usbhost_state_s *priv,
+                                        uint8_t slotno)
+{
+  FAR struct usbhost_hubport_s *hport = priv->usbclass.hport;
+  uint8_t xbox360w_inquire_present[] =
+  {
+    0x08, 0x00, 0x0f, 0xc0
+  };
+
+  DEBUGASSERT(slotno < priv->nslots);
+  return DRVR_TRANSFER(hport->drvr, priv->slots[slotno].epout,
+                       xbox360w_inquire_present,
+                       sizeof(xbox360w_inquire_present));
+}
+
+/****************************************************************************
+ * Name: usbhost_parse_xboxone
+ *
+ * Description:
+ *   Parse Xbox One/Series GIP reports.  This preserves the original driver
+ *   initialization, guide-button ACK, and input packet behavior.
+ *
+ ****************************************************************************/
+
+static int usbhost_parse_xboxone(FAR struct usbhost_state_s *priv,
+                                 ssize_t nbytes)
+{
+  FAR struct usbhost_hubport_s *hport = priv->usbclass.hport;
+  struct xbox_controller_buttonstate_s rpt;
+  uint8_t seq_num;
+  int ret;
+
+  switch (priv->tbuffer[0])
+    {
+    case USBHOST_WAITING_CONNECTION:
+      /* Send the initialization message when we receive the first waiting
+       * connection message.
+       */
+
+      if (!priv->initialized)
+        {
+          ret = nxmutex_lock(&priv->lock);
+          if (ret < 0)
+            {
+              return ret;
+            }
+
+          priv->tbuffer[0] = 0x05;
+          priv->tbuffer[1] = 0x20;
+          priv->tbuffer[2] = priv->out_seq_num++;
+          priv->tbuffer[3] = 0x01;
+          priv->tbuffer[4] = 0x00;
+          DRVR_TRANSFER(hport->drvr, priv->epout, priv->tbuffer, 5);
+          priv->initialized = true;
+
+          nxmutex_unlock(&priv->lock);
+        }
+
+      break;
+
+    case USBHOST_GUIDE_BUTTON_STATUS:
+      if (nbytes <= XBOX_BUTTON_GUIDE_INDEX)
+        {
+          uerr("ERROR: Short guide status report: %d\n", (int)nbytes);
+          break;
+        }
+
+      ret = nxmutex_lock(&priv->lock);
+      if (ret < 0)
+        {
+          return ret;
+        }
+
+      priv->rpt.guide =
+        (priv->tbuffer[XBOX_BUTTON_GUIDE_INDEX] != 0) ? true : false;
+      priv->valid = true;
+
+      /* The One X controller requires an ACK of the guide button status
+       * message.
+       */
+
+      if (priv->tbuffer[1] == 0x30)
+        {
+          static const uint8_t guide_button_report_ack[] =
+          {
+            0x01, 0x20, 0x00, 0x09, 0x00, 0x07, 0x20, 0x02,
+            0x00, 0x00, 0x00, 0x00, 0x00
+          };
+
+          seq_num = priv->tbuffer[2];
+          memcpy(priv->tbuffer, guide_button_report_ack,
+                 sizeof(guide_button_report_ack));
+          priv->tbuffer[2] = seq_num;
+
+          DRVR_TRANSFER(hport->drvr, priv->epout, priv->tbuffer,
+                        sizeof(guide_button_report_ack));
+        }
+
+      usbhost_pollnotify(priv);
+      nxmutex_unlock(&priv->lock);
+      break;
+
+    case USBHOST_BUTTON_DATA:
+      if (!priv->open)
+        {
+          break;
+        }
+
+      if (nbytes < 18)
+        {
+          uerr("ERROR: Short Xbox One input report: %d\n", (int)nbytes);
+          break;
+        }
+
+      memset(&rpt, 0, sizeof(rpt));
+      rpt.guide = priv->rpt.guide;
+      rpt.sync =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_SYNC_INDEX,
+                        XBOX_BUTTON_SYNC_MASK);
+      rpt.start =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_START_INDEX,
+                        XBOX_BUTTON_START_MASK);
+      rpt.back =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_BACK_INDEX,
+                        XBOX_BUTTON_BACK_MASK);
+      rpt.a =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_A_INDEX,
+                        XBOX_BUTTON_A_MASK);
+      rpt.b =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_B_INDEX,
+                        XBOX_BUTTON_B_MASK);
+      rpt.x =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_X_INDEX,
+                        XBOX_BUTTON_X_MASK);
+      rpt.y =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_Y_INDEX,
+                        XBOX_BUTTON_Y_MASK);
+      rpt.dpad_up =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_DPAD_UP_INDEX,
+                        XBOX_BUTTON_DPAD_UP_MASK);
+      rpt.dpad_down =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_DPAD_DOWN_INDEX,
+                        XBOX_BUTTON_DPAD_DOWN_MASK);
+      rpt.dpad_left =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_DPAD_LEFT_INDEX,
+                        XBOX_BUTTON_DPAD_LEFT_MASK);
+      rpt.dpad_right =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_DPAD_RIGHT_INDEX,
+                        XBOX_BUTTON_DPAD_RIGHT_MASK);
+      rpt.bumper_left =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_BUMPER_LEFT_INDEX,
+                        XBOX_BUTTON_BUMPER_LEFT_MASK);
+      rpt.bumper_right =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_BUMPER_RIGHT_INDEX,
+                        XBOX_BUTTON_BUMPER_RIGHT_MASK);
+      rpt.stick_click_left =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_STICK_LEFT_INDEX,
+                        XBOX_BUTTON_STICK_LEFT_MASK);
+      rpt.stick_click_right =
+        XBOX_BUTTON_SET(priv->tbuffer,
+                        XBOX_BUTTON_STICK_RIGHT_INDEX,
+                        XBOX_BUTTON_STICK_RIGHT_MASK);
+
+      rpt.trigger_left = usbhost_getle16s(&priv->tbuffer[6]);
+      rpt.trigger_right = usbhost_getle16s(&priv->tbuffer[8]);
+      rpt.stick_left_x = usbhost_getle16s(&priv->tbuffer[10]);
+      rpt.stick_left_y = usbhost_getle16s(&priv->tbuffer[12]);
+      rpt.stick_right_x = usbhost_getle16s(&priv->tbuffer[14]);
+      rpt.stick_right_y = usbhost_getle16s(&priv->tbuffer[16]);
+
+      return usbhost_publish(priv, &rpt);
+
+    default:
+      uinfo("Received Xbox One message type: %x\n", priv->tbuffer[0]);
+      break;
+    }
+
+  return OK;
+}
+
+/****************************************************************************
+ * Name: usbhost_parse_xbox360w
+ *
+ * Description:
+ *   Parse Xbox 360 wireless receiver packets.  Constants and packet layout
+ *   are based on the MIT-licensed TinyUSB XInput host reference in wili8jam.
+ *
+ ****************************************************************************/
+
+static int usbhost_parse_xbox360w(FAR struct usbhost_state_s *priv,
+                                  uint8_t slotno, ssize_t nbytes)
+{
+  FAR struct xboxcontroller_slot_s *slot;
+  struct xbox_controller_buttonstate_s rpt;
+  uint16_t buttons;
+  bool connected;
+  int ret;
+
+  DEBUGASSERT(slotno < priv->nslots);
+  slot = &priv->slots[slotno];
+
+  if (nbytes < 2)
+    {
+      uerr("ERROR: Short Xbox 360 wireless report: %d\n", (int)nbytes);
+      return OK;
+    }
+
+  /* Connect/disconnect packet.  The receiver remains attached even when no
+   * wireless controller is paired.
+   */
+
+  if ((priv->tbuffer[0] & 0x08) != 0)
+    {
+      connected = priv->tbuffer[1] != 0x00;
+
+      if (connected != slot->connected)
+        {
+          uinfo("Xbox 360 wireless slot %u %s\n",
+                slotno, connected ? "connected" : "disconnected");
+
+          ret = nxmutex_lock(&priv->lock);
+          if (ret < 0)
+            {
+              return ret;
+            }
+
+          slot->connected = connected;
+          priv->connected = usbhost_360w_any_connected(priv);
+          if (!connected && slotno == priv->active_slot)
+            {
+              memset(&priv->rpt, 0,
+                     sizeof(struct xbox_controller_buttonstate_s));
+              priv->valid = true;
+              usbhost_pollnotify(priv);
+            }
+
+          nxmutex_unlock(&priv->lock);
+        }
+    }
+
+  /* Button status packet. */
+
+  if (nbytes < XBOX_360W_MIN_PACKET_SIZE ||
+      (priv->tbuffer[1] & 1) == 0 ||
+      priv->tbuffer[5] != 0x13)
+    {
+      return OK;
+    }
+
+  uinfo("Xbox 360 wireless input slot %u len=%d\n",
+        slotno, (int)nbytes);
+
+  ret = nxmutex_lock(&priv->lock);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  slot->connected = true;
+  priv->connected = true;
+  priv->active_slot = slotno;
+  nxmutex_unlock(&priv->lock);
+
+  memset(&rpt, 0, sizeof(rpt));
+  buttons = ((uint16_t)priv->tbuffer[7] << 8) | priv->tbuffer[6];
+
+  rpt.dpad_up = (buttons & (1 << 0)) != 0;
+  rpt.dpad_down = (buttons & (1 << 1)) != 0;
+  rpt.dpad_left = (buttons & (1 << 2)) != 0;
+  rpt.dpad_right = (buttons & (1 << 3)) != 0;
+  rpt.start = (buttons & (1 << 4)) != 0;
+  rpt.back = (buttons & (1 << 5)) != 0;
+  rpt.stick_click_left = (buttons & (1 << 6)) != 0;
+  rpt.stick_click_right = (buttons & (1 << 7)) != 0;
+  rpt.bumper_left = (buttons & (1 << 8)) != 0;
+  rpt.bumper_right = (buttons & (1 << 9)) != 0;
+  rpt.guide = (buttons & (1 << 10)) != 0;
+  rpt.a = (buttons & (1 << 12)) != 0;
+  rpt.b = (buttons & (1 << 13)) != 0;
+  rpt.x = (buttons & (1 << 14)) != 0;
+  rpt.y = (buttons & (1 << 15)) != 0;
+
+  rpt.trigger_left = priv->tbuffer[8];
+  rpt.trigger_right = priv->tbuffer[9];
+  rpt.stick_left_x = usbhost_getle16s(&priv->tbuffer[10]);
+  rpt.stick_left_y = usbhost_getle16s(&priv->tbuffer[12]);
+  rpt.stick_right_x = usbhost_getle16s(&priv->tbuffer[14]);
+  rpt.stick_right_y = usbhost_getle16s(&priv->tbuffer[16]);
+
+  return usbhost_publish(priv, &rpt);
+}
