+/****************************************************************************
+ * Name: usbhost_publish
+ *
+ * Description:
+ *   Publish a parsed controller report to read()/poll() waiters.
+ *
+ ****************************************************************************/
+
+static int usbhost_publish(FAR struct usbhost_state_s *priv,
+                           FAR const struct
+                           xbox_controller_buttonstate_s *rpt)
+{
+  int ret;
+
+  ret = nxmutex_lock(&priv->lock);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  memcpy(&priv->rpt, rpt, sizeof(struct xbox_controller_buttonstate_s));
+  priv->valid = true;
+  usbhost_pollnotify(priv);
+
+  nxmutex_unlock(&priv->lock);
+  return OK;
+}
