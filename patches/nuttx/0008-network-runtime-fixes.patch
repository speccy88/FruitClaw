+/****************************************************************************
+ * Name: telnet_sendall
+ *
+ * Description:
+ *   Send a complete Telnet protocol or data buffer.  A successful stream
+ *   socket send may consume fewer bytes than requested, and signals may
+ *   interrupt a blocking send before any data is accepted.
+ *
+ ****************************************************************************/
+
+static ssize_t telnet_sendall(FAR struct telnet_dev_s *priv,
+                              FAR const void *buffer, size_t len)
+{
+  FAR const uint8_t *src = buffer;
+  size_t offset = 0;
+  ssize_t ret;
+
+  while (offset < len)
+    {
+      ret = psock_send(&priv->td_psock, src + offset, len - offset, 0);
+      if (ret > 0)
+        {
+          offset += ret;
+        }
+      else if (ret == -EINTR)
+        {
+          continue;
+        }
+      else
+        {
+          return ret == 0 ? -EPIPE : ret;
+        }
+    }
+
+  return offset;
+}
+
