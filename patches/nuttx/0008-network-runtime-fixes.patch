diff --git a/drivers/wireless/Kconfig b/drivers/wireless/Kconfig
index 15f51deb35f5e58bd5430ae000d3a0a5224ba5c3..88397ec2ec35256d41c694ab7a8ce5f4553f2322 100644
--- a/drivers/wireless/Kconfig
+++ b/drivers/wireless/Kconfig
@@ -178,6 +178,33 @@ config ESP_HOSTED_SPI_MODE
 		SPI mode used for ESP-Hosted full-duplex transport.  ESP-Hosted
 		slave firmware does not support mode 0.
 
+config ESP_HOSTED_RX_WORK_DRAIN_LIMIT
+	int "Maximum frames drained per ESP-Hosted worker pass"
+	default 32
+	range 1 64
+	depends on ESP_HOSTED_SPI
+	---help---
+		Maximum number of receive frames processed by one worker pass.
+		Lower values reduce work-queue occupancy and peak IOB pressure;
+		higher values can improve receive throughput when buffers permit.
+
+config ESP_HOSTED_RX_POLL_DELAY_MS
+	int "ESP-Hosted active receive poll delay (ms)"
+	default 25
+	range 1 1000
+	depends on ESP_HOSTED_SPI
+	---help---
+		Delay between receive polls while recent traffic indicates a burst.
+
+config ESP_HOSTED_RX_IDLE_POLL_DELAY_MS
+	int "ESP-Hosted idle receive poll delay (ms)"
+	default 100
+	range 1 10000
+	depends on ESP_HOSTED_SPI
+	---help---
+		Background receive poll delay when no burst traffic is detected.
+		Periodic polling recovers from missed data-ready GPIO edges.
+
 endif # ESP_HOSTED
 
