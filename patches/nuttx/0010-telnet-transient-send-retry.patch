 /****************************************************************************
+ * Name: telnet_deadline
+ *
+ * Description:
+ *   Compute one absolute deadline for a complete logical Telnet write.
+ *
+ ****************************************************************************/
+
+static int telnet_deadline(FAR struct timespec *deadline)
+{
+  if (clock_gettime(CLOCK_MONOTONIC, deadline) < 0)
+    {
+      return -errno;
+    }
+
+  deadline->tv_sec += CONFIG_TELNET_SEND_TIMEOUT_MS / 1000;
+  deadline->tv_nsec +=
+    (CONFIG_TELNET_SEND_TIMEOUT_MS % 1000) * 1000000;
+  if (deadline->tv_nsec >= 1000000000)
+    {
+      deadline->tv_sec++;
+      deadline->tv_nsec -= 1000000000;
+    }
+
+  return OK;
+}
