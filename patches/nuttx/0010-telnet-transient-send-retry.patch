 /****************************************************************************
+ * Name: telnet_sendopt
+ ****************************************************************************/
+
+static int telnet_sendopt(FAR struct telnet_dev_s *priv, uint8_t option,
+                          uint8_t value)
+{
+  struct timespec deadline;
+  int ret;
+
+  ret = telnet_deadline(&deadline);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  ret = nxmutex_clocklock(&priv->td_txlock, CLOCK_MONOTONIC, &deadline);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  ret = telnet_sendopt_locked(priv, option, value, &deadline);
+  if (ret < 0)
+    {
+      psock_shutdown(&priv->td_psock, SHUT_RDWR);
+    }
+
+  nxmutex_unlock(&priv->td_txlock);
+  return ret;
+}
