 /****************************************************************************
+ * Name: telnet_negotiate
+ ****************************************************************************/
+
+static int telnet_negotiate(FAR struct telnet_dev_s *priv)
+{
+  struct timespec deadline;
+  int ret;
+
+  ret = telnet_deadline(&deadline);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  ret = nxmutex_clocklock(&priv->td_txlock, CLOCK_MONOTONIC, &deadline);
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+#ifdef CONFIG_TELNET_SUPPORT_NAWS
+  if (ret >= 0)
+    {
+      ret = telnet_sendopt_locked(priv, TELNET_DO, TELNET_NAWS, &deadline);
+    }
+#endif
+  if (ret >= 0)
+    {
+      ret = telnet_sendopt_locked(priv, TELNET_WILL, TELNET_SGA, &deadline);
+    }
+
+  if (ret >= 0)
+    {
+      ret = telnet_sendopt_locked(priv, TELNET_DO, TELNET_SGA, &deadline);
+    }
+
+  if (ret >= 0)
+    {
+      ret = telnet_sendopt_locked(priv, TELNET_WILL, TELNET_ECHO, &deadline);
+    }
+
+  if (ret < 0)
+    {
+      psock_shutdown(&priv->td_psock, SHUT_RDWR);
+    }
+
+  nxmutex_unlock(&priv->td_txlock);
+  return ret;
+}
