 /****************************************************************************
+ * Name: ftpd_isshutdown
+ ****************************************************************************/
+
+static bool ftpd_isshutdown(FAR struct ftpd_session_s *session)
+{
+  bool shutdown;
+
+  pthread_mutex_lock(&session->lock);
+  shutdown = session->shutdown;
+  pthread_mutex_unlock(&session->lock);
+  return shutdown;
+}
