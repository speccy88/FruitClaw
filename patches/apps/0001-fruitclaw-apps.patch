+static void be_lvgl_warn_power(void)
+{
+  int fd;
+  int power = 0;
+
+  fd = open(BE_LVGL_FB_PATH, O_RDWR);
+  if (fd < 0)
+    {
+      return;
+    }
+
+  if (ioctl(fd, FBIOGET_POWER, (unsigned long)((uintptr_t)&power)) >= 0 &&
+      power == 0)
+    {
+      printf("lv: framebuffer is powered off; run 'dvictrl start' for DVI\n");
+    }
+
+  close(fd);
+}
