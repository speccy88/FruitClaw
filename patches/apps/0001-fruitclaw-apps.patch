+static void be_lvgl_keyboard_init(lv_display_t *disp)
+{
+  struct be_lvgl_keyboard_s *keyboard = &g_lvgl_keyboard;
+
+  keyboard->group = lv_group_create();
+  if (keyboard->group == NULL)
+    {
+      LV_LOG_WARN("Failed to create Berry LVGL keyboard group");
+      return;
+    }
+
+  lv_group_set_default(keyboard->group);
+  keyboard->indev = lv_indev_create();
+  if (keyboard->indev == NULL)
+    {
+      LV_LOG_WARN("Failed to create Berry LVGL keyboard input");
+      lv_group_delete(keyboard->group);
+      keyboard->group = NULL;
+      return;
+    }
+
+  lv_indev_set_type(keyboard->indev, LV_INDEV_TYPE_KEYPAD);
+  lv_indev_set_read_cb(keyboard->indev, be_lvgl_keyboard_read);
+  lv_indev_set_driver_data(keyboard->indev, keyboard);
+  lv_indev_set_display(keyboard->indev, disp);
+  lv_indev_set_group(keyboard->indev, keyboard->group);
+
+  be_lvgl_keyboard_open(keyboard);
+}
