+#endif
+  printf("\n");
+  printf("mcp_server: %s\n",
+#ifdef CONFIG_FRUITCLAW_MCP_SERVER
+         "enabled"
+#else
+         "disabled"
+#endif
+         );
+#ifdef CONFIG_FRUITCLAW_MCP_SERVER
+  printf("mcp_yolo_mode: %s\n",
+#  ifdef CONFIG_FRUITCLAW_MCP_YOLO_MODE
+         "yes"
+#  else
+         "no"
+#  endif
+         );
+#endif
+  return 0;
+}
