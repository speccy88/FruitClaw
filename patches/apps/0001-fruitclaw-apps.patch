+#if defined(CONFIG_INPUT_KEYBOARD) && defined(CONFIG_LV_USE_KEYBOARD)
+static bool be_lvgl_keyboard_shifted(
+    const struct be_lvgl_keyboard_s *keyboard)
+{
+  return keyboard->modifiers != 0;
+}
+
+static uint32_t be_lvgl_keyboard_shift_ascii(
+    const struct be_lvgl_keyboard_s *keyboard, uint32_t code)
+{
+  bool shifted = be_lvgl_keyboard_shifted(keyboard);
+
+  if (code >= 'a' && code <= 'z')
+    {
+      if (shifted != keyboard->capslock)
+        {
+          return code - 'a' + 'A';
+        }
+
+      return code;
+    }
+
+  if (!shifted)
+    {
+      return code;
+    }
+
+  switch (code)
+    {
+      case '1': return '!';
+      case '2': return '@';
+      case '3': return '#';
+      case '4': return '$';
+      case '5': return '%';
+      case '6': return '^';
+      case '7': return '&';
+      case '8': return '*';
+      case '9': return '(';
+      case '0': return ')';
+      case '-': return '_';
+      case '=': return '+';
+      case '[': return '{';
+      case ']': return '}';
+      case '\\': return '|';
+      case ';': return ':';
+      case '\'': return '"';
+      case '`': return '~';
+      case ',': return '<';
+      case '.': return '>';
+      case '/': return '?';
+      default: return code;
+    }
+}
+
+static void be_lvgl_keyboard_modifier(struct be_lvgl_keyboard_s *keyboard,
+                                      uint32_t code, uint32_t type)
+{
+  uint8_t modifier = 0;
+
+  switch (code)
+    {
+      case XK_Shift_L:
+        modifier = BE_LVGL_KBD_MOD_LSHIFT;
+        break;
+
+      case XK_Shift_R:
+        modifier = BE_LVGL_KBD_MOD_RSHIFT;
+        break;
+
+#ifdef CONFIG_HIDKBD_INPUT_DOSKEYS
+      case BE_LVGL_DOS_KEY_RSHIFT:
+        modifier = BE_LVGL_KBD_MOD_RSHIFT;
+        break;
+#endif
+
+      default:
+        return;
+    }
+
+  if (type == KEYBOARD_PRESS)
+    {
+      keyboard->modifiers |= modifier;
+    }
+  else
+    {
+      keyboard->modifiers &= ~modifier;
+    }
+}
+
+static bool be_lvgl_keyboard_keycode(struct be_lvgl_keyboard_s *keyboard,
+                                     const struct keyboard_event_s *event,
+                                     uint32_t *key)
+{
+  be_lvgl_keyboard_modifier(keyboard, event->code, event->type);
+
+  if ((event->code == KEYCODE_CAPSLOCK
+#ifdef CONFIG_HIDKBD_INPUT_DOSKEYS
+       || event->code == BE_LVGL_DOS_KEY_CAPSLOCK
+#endif
+      ) && event->type == KEYBOARD_PRESS)
+    {
+      keyboard->capslock = !keyboard->capslock;
+      return false;
+    }
+
+#ifdef CONFIG_HIDKBD_INPUT_DOSKEYS
+  switch (event->code)
+    {
+      case BE_LVGL_DOS_KEY_RSHIFT:
+        return false;
+
+      case BE_LVGL_DOS_KEY_ENTER:
+        *key = LV_KEY_ENTER;
+        return true;
+
+      case BE_LVGL_DOS_KEY_ESCAPE:
+        *key = LV_KEY_ESC;
+        return true;
+
+      case BE_LVGL_DOS_KEY_TAB:
+        *key = be_lvgl_keyboard_shifted(keyboard) ?
+               LV_KEY_PREV : LV_KEY_NEXT;
+        return true;
+
+      case BE_LVGL_DOS_KEY_BACKSPACE:
+        *key = LV_KEY_BACKSPACE;
+        return true;
+
+      case BE_LVGL_DOS_KEY_DEL:
+        *key = LV_KEY_DEL;
+        return true;
+
+      case BE_LVGL_DOS_KEY_HOME:
+        *key = LV_KEY_HOME;
+        return true;
+
+      case BE_LVGL_DOS_KEY_END:
+        *key = LV_KEY_END;
+        return true;
+
+      case BE_LVGL_DOS_KEY_LEFTARROW:
+        *key = LV_KEY_LEFT;
+        return true;
+
+      case BE_LVGL_DOS_KEY_RIGHTARROW:
+        *key = LV_KEY_RIGHT;
+        return true;
+
+      case BE_LVGL_DOS_KEY_UPARROW:
+      case BE_LVGL_DOS_KEY_PGUP:
+        *key = LV_KEY_UP;
+        return true;
+
+      case BE_LVGL_DOS_KEY_DOWNARROW:
+      case BE_LVGL_DOS_KEY_PGDN:
+        *key = LV_KEY_DOWN;
+        return true;
+
+      default:
+        break;
+    }
+#endif
+
+  switch (event->code)
+    {
+      case XK_Shift_L:
+      case XK_Shift_R:
+      case XK_Control_L:
+      case XK_Control_R:
+      case XK_Alt_L:
+      case XK_Alt_R:
+      case XK_Meta_L:
+      case XK_Meta_R:
+        return false;
+
+      case KEYCODE_ENTER:
+      case XK_Return:
+      case XK_KP_Enter:
+        *key = LV_KEY_ENTER;
+        return true;
+
+      case XK_Escape:
+        *key = LV_KEY_ESC;
+        return true;
+
+      case XK_Tab:
+      case XK_KP_Tab:
+        *key = be_lvgl_keyboard_shifted(keyboard) ?
+               LV_KEY_PREV : LV_KEY_NEXT;
+        return true;
+
+      case XK_BackSpace:
+      case KEYCODE_BACKDEL:
+        *key = LV_KEY_BACKSPACE;
+        return true;
+
+      case XK_Delete:
+      case KEYCODE_FWDDEL:
+        *key = LV_KEY_DEL;
+        return true;
+
+      case KEYCODE_HOME:
+      case XK_Home:
+      case XK_KP_Home:
+        *key = LV_KEY_HOME;
+        return true;
+
+      case KEYCODE_END:
+      case XK_End:
+      case XK_KP_End:
+        *key = LV_KEY_END;
+        return true;
+
+      case KEYCODE_LEFT:
+      case XK_Left:
+      case XK_KP_Left:
+        *key = LV_KEY_LEFT;
+        return true;
+
+      case KEYCODE_RIGHT:
+      case XK_Right:
+      case XK_KP_Right:
+        *key = LV_KEY_RIGHT;
+        return true;
+
+      case KEYCODE_UP:
+      case XK_Up:
+      case XK_KP_Up:
+      case KEYCODE_PAGEUP:
+      case XK_Page_Up:
+      case XK_KP_Page_Up:
+        *key = LV_KEY_UP;
+        return true;
+
+      case KEYCODE_DOWN:
+      case XK_Down:
+      case XK_KP_Down:
+      case KEYCODE_PAGEDOWN:
+      case XK_Page_Down:
+      case XK_KP_Page_Down:
+        *key = LV_KEY_DOWN;
+        return true;
+
+      default:
+        if (event->code >= 0x20 && event->code <= 0x7e)
+          {
+            *key = be_lvgl_keyboard_shift_ascii(keyboard, event->code);
+            return true;
+          }
+
+        return false;
+    }
+}
+
+static void be_lvgl_keyboard_open(struct be_lvgl_keyboard_s *keyboard)
+{
+  keyboard->last_open = lv_tick_get();
+  keyboard->fd = open(BE_LVGL_KBD_PATH, O_RDONLY | O_NONBLOCK);
+  if (keyboard->fd >= 0)
+    {
+      LV_LOG_INFO("Berry LVGL keyboard input attached to %s",
+                  BE_LVGL_KBD_PATH);
+    }
+}
+
+static void be_lvgl_keyboard_read(lv_indev_t *indev, lv_indev_data_t *data)
+{
+  struct be_lvgl_keyboard_s *keyboard = lv_indev_get_driver_data(indev);
+  struct keyboard_event_s event;
+  uint32_t key;
+  ssize_t nread;
+
+  if (keyboard->fd < 0 &&
+      lv_tick_get() - keyboard->last_open >= BE_LVGL_KBD_RETRY)
+    {
+      be_lvgl_keyboard_open(keyboard);
+    }
+
+  while (keyboard->fd >= 0)
+    {
+      nread = read(keyboard->fd, &event, sizeof(event));
+      if (nread != sizeof(event))
+        {
+          if (nread < 0 && errno != EAGAIN && errno != EINTR)
+            {
+              close(keyboard->fd);
+              keyboard->fd = -1;
+              keyboard->last_open = lv_tick_get();
+            }
+
+          break;
+        }
+
+      if (be_lvgl_keyboard_keycode(keyboard, &event, &key))
+        {
+          keyboard->key = key;
+          keyboard->state = event.type == KEYBOARD_PRESS ?
+                            LV_INDEV_STATE_PRESSED :
+                            LV_INDEV_STATE_RELEASED;
+          data->continue_reading = true;
+          break;
+        }
+    }
+
+  data->key = keyboard->key;
+  data->state = keyboard->state;
+}
