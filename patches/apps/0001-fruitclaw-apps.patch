+      fprintf(stderr, "ERROR: VBUS cycle failed: %d\n", ret);
+      return EXIT_FAILURE;
+    }
+
+  g_piousbhost_post_start_done = false;
+  printf("piousbhost: VBUS cycled\n");
+  return EXIT_SUCCESS;
+}
