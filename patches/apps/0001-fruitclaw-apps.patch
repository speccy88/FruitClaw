+static bool fc_rtttl_arg_safe(const char *tune)
+{
+  const char *p;
+
+  if (tune == NULL || tune[0] == '\0' ||
+      strlen(tune) > FC_RTTTL_MAX_TUNE)
+    {
+      return false;
+    }
+
+  for (p = tune; *p != '\0'; p++)
+    {
+      if (!isalnum((unsigned char)*p) && *p != ':' && *p != ',' &&
+          *p != '=' && *p != '#' && *p != '.' && *p != '_' &&
+          *p != '-')
+        {
+          return false;
+        }
+    }
+
+  return true;
+}
