+static int32_t be_lvgl_clip_axis(int32_t value, int32_t limit)
+{
+  if (value < 0)
+    {
+      return 0;
+    }
+
+  if (value >= limit)
+    {
+      return limit - 1;
+    }
+
+  return value;
+}
