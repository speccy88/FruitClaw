+           "webserver: supervisor=%s listening=%s listens=%lu exits=%lu "
+           "last_ret=%d last_errno=%d last_start_age_ms=%lld "
+           "last_exit_age_ms=%lld",
+           started ? "started" : "stopped",
+           listening ? "yes" : "no", listens, exits, last_ret, last_errno,
