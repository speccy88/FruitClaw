+
 /****************************************************************************
  * Private Data
  ****************************************************************************/
 
+#ifdef CONFIG_INPUT_MOUSE
+static struct lvgldemo_mouse_s g_lvgldemo_mouse =
+{
+  .fd = -1
+};
+#endif
+
+#ifdef CONFIG_INPUT_KEYBOARD
+static struct lvgldemo_keyboard_s g_lvgldemo_keyboard =
+{
