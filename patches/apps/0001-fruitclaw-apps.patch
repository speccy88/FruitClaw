+      if (color_esc[0] != '\0')
+        {
+          snprintf(args, sizeof(args),
+                   "{\"effect\":\"%s\",\"color\":\"%s\"}",
+                   effect_esc, color_esc);
+        }
+      else
+        {
+          snprintf(args, sizeof(args), "{\"effect\":\"%s\"}", effect_esc);
+        }
+
+      berry_claw_call_tool("neopixels.effect", args, result,
