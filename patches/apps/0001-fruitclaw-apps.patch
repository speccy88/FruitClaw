+  </style>
+</head>
+<body>
+  <header class="banner">
+    <strong>FruitClaw</strong>
+    <span>Adafruit Fruit Jam RP2350 NuttX operator image</span>
+    <a href="/docs/">Open /docs Manual</a>
+  </header>
+
+  <section class="hero" aria-label="Documentation shortcut">
+    <p>
+      This is the editable board home page. The full usage manual, build notes,
+      installed utilities, hardware details, kernel devices, MCP tools, and
+      troubleshooting guide live at <a href="/docs/">/docs/</a>.
+    </p>
+  </section>
+
+  <main id="content" aria-live="polite">
+    <p>Loading FruitClaw home...</p>
+  </main>
+
+  <footer>
+    This page is served by the embedded NuttX uIP webserver. Its Markdown
+    content can be updated from FruitClaw or MCP.
+  </footer>
+
+  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
+  <script src="https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js"></script>
+  <script>
+  (function () {
+    "use strict";
+
+    var content = document.getElementById("content");
+    var fallback = [
+      "# FruitClaw",
+      "",
+      "FruitClaw is running. Use the documentation link above for setup, tools,",
+      "MCP, Telegram, Berry, scheduler, hardware, kernel devices, and recovery notes.",
+      "",
+      "From MCP or Telegram, update this home page with the `web.home.write` tool."
+    ].join("\n");
+
+    function escapeHtml(text) {
+      return String(text).replace(/[&<>"']/g, function (ch) {
+        return {
+          "&": "&amp;",
+          "<": "&lt;",
+          ">": "&gt;",
+          '"': "&quot;",
+          "'": "&#39;"
+        }[ch];
+      });
+    }
+
+    function renderMarkdown(text) {
+      if (window.marked && window.DOMPurify) {
+        return DOMPurify.sanitize(marked.parse(text));
+      }
+
+      return "<pre>" + escapeHtml(text) + "</pre>";
+    }
+
+    function show(text) {
+      content.innerHTML = renderMarkdown(text || fallback);
+    }
+
+    fetch("/site/home.md", { cache: "no-cache" })
+      .then(function (response) {
+        if (!response.ok) {
+          throw new Error("home markdown returned HTTP " + response.status);
+        }
+
+        return response.text();
+      })
+      .then(show)
+      .catch(function () {
+        show(fallback);
+      });
+  }());
+  </script>
+</body>
+</html>
