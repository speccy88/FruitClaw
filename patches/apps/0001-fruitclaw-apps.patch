+    }
+
+  if (fc_dir_exists(CONFIG_FRUITCLAW_SD_DATA_DIR))
+    {
+      if (access(marker, F_OK) == 0)
+        {
+          return true;
+        }
+    }
+  else if (fc_mkdir_p(CONFIG_FRUITCLAW_SD_DATA_DIR) < 0)
+    {
+      return false;
+    }
+
+  fd = open(marker, O_WRONLY | O_CREAT | O_TRUNC, 0664);
+  if (fd < 0)
+    {
+      return false;
+    }
+
+  close(fd);
