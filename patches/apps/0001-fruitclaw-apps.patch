+static const struct webclient_tls_ops g_trmnl_tls_ops =
+{
+  .connect = trmnl_tls_connect,
+  .send = trmnl_tls_send,
+  .recv = trmnl_tls_recv,
+  .close = trmnl_tls_close,
+  .get_poll_info = trmnl_tls_get_poll_info,
+  .init_connection = NULL,
+};
+#endif
