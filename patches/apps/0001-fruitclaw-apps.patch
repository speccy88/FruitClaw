+static int fc_telegram_read_token(char *token, size_t token_len)
+{
+  char path[FC_PATH_LEN];
+  int ret;
+
+  ret = fc_secret_path("telegram_token", path, sizeof(path));
+  if (ret < 0)
+    {
+      return ret;
+    }
+
+  return fc_read_text_file(path, token, token_len, true);
+}
