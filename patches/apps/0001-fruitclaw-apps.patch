+static int cap_gpio_stub(const fc_tool_context_t *ctx, const char *args_json,
+                         char *out, size_t out_len)
+{
+  (void)ctx;
+  (void)args_json;
+  snprintf(out, out_len,
+           "{\"ok\":false,\"error\":\"GPIO tool not configured\"}");
+  return -ENOSYS;
+}
