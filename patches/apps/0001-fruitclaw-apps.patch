+static bool fc_color_lookup(const char *name, uint8_t *r, uint8_t *g,
+                            uint8_t *b)
+{
+  size_t i;
+
+  if (name == NULL)
+    {
+      return false;
+    }
+
+  for (i = 0; i < sizeof(g_colors) / sizeof(g_colors[0]); i++)
+    {
+      if (strcmp(name, g_colors[i].name) == 0)
+        {
+          *r = g_colors[i].r;
+          *g = g_colors[i].g;
+          *b = g_colors[i].b;
+          return true;
+        }
+    }
+
+  return false;
+}
