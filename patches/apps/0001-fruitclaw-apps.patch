+int fc_mkdir_p(const char *path)
+{
+  char tmp[FC_PATH_LEN];
+  char *p;
+
+  if (path == NULL || path[0] == '\0')
+    {
+      return -EINVAL;
+    }
+
+  if (fc_strlcpy(tmp, path, sizeof(tmp)) < 0)
+    {
+      return -ENAMETOOLONG;
+    }
+
+  for (p = tmp + 1; *p != '\0'; p++)
+    {
+      if (*p == '/')
+        {
+          *p = '\0';
+          if (!fc_mkdir_skip_mount_root(tmp) &&
+              mkdir(tmp, 0775) < 0 && errno != EEXIST)
+            {
+              return -errno;
+            }
+
+          *p = '/';
+        }
+    }
+
+  if (!fc_mkdir_skip_mount_root(tmp) &&
+      mkdir(tmp, 0775) < 0 && errno != EEXIST)
+    {
+      return -errno;
+    }
+
+  return 0;
