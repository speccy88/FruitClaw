+static FAR char *rtttl_join_args(int argc, FAR char *argv[], int first)
+{
+  FAR char *joined;
+  size_t len = 1;
+  int i;
+
+  for (i = first; i < argc; i++)
+    {
+      len += strlen(argv[i]) + 1;
+    }
+
+  joined = malloc(len);
+  if (joined == NULL)
+    {
+      return NULL;
+    }
+
+  joined[0] = '\0';
+  for (i = first; i < argc; i++)
+    {
+      if (i != first)
+        {
+          strlcat(joined, " ", len);
+        }
+
+      strlcat(joined, argv[i], len);
+    }
+
+  return joined;
+}
