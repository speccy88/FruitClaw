+static int be_lvgl_millis(bvm *vm)
+{
+  struct timeval tv;
+  uint64_t ms;
+
+  gettimeofday(&tv, NULL);
+  ms = (uint64_t)tv.tv_sec * 1000 + (uint64_t)tv.tv_usec / 1000;
+  be_pushint(vm, (bint)(ms & 0x7fffffff));
+  be_return(vm);
+}
