+static int be_lvgl_sleep_ms(bvm *vm)
+{
+  int32_t ms = be_lvgl_intarg(vm, 1, 0);
+
+  if (ms > 0)
+    {
+      usleep((useconds_t)ms * 1000);
+    }
+
+  be_return_nil(vm);
+}
