+static FAR const char *rtttl_builtin(FAR const char *name)
+{
+  size_t i;
+
+  for (i = 0; i < nitems(g_rtttl_builtins); i++)
+    {
+      if (strcasecmp(name, g_rtttl_builtins[i].name) == 0)
+        {
+          return g_rtttl_builtins[i].rtttl;
+        }
+    }
+
+  return NULL;
+}
