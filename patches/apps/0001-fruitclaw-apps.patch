+assert(t2.g() == false)
+assert_attribute_error(/-> t2.h())
+
+#- try virtual methods -#
+assert(t2.f1() == t2)
+assert(t2.f2() == 4)
+assert(t2.a1 == 10)
+assert(t2.foo == nil)
+
+#- module -#
+m = module("m")
+
+m.a = 1
+assert(m.a == 1)
+assert_attribute_error(/-> m.b)
+
+m.member = def(n)
+    import undefined
+    if n == "b" return 2 end
+    if n == "c" return undefined end
+end
+
