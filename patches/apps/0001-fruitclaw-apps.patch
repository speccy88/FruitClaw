+int fc_register_builtin_caps(void)
+{
+  unsigned int i;
+  int ret;
+
+  for (i = 0; i < sizeof(g_caps) / sizeof(g_caps[0]); i++)
+    {
+      ret = fc_cap_register(&g_caps[i]);
+      if (ret < 0)
+        {
+          return ret;
+        }
+    }
+
+  return 0;
+}
