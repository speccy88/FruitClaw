+config FRUITCLAW_BERRY_TRACE
+	bool "Trace FruitClaw Berry runner stages"
+	default n
+	depends on FRUITCLAW_ENABLE_BERRY
+
+config FRUITCLAW_BERRY_EXPERIMENTAL_RUNNER
+	bool "Enable embedded Berry runner"
+	default y
+	depends on FRUITCLAW_ENABLE_BERRY
+	---help---
+		Enable the direct Berry VM wrapper used by berry.run_script and
+		fruitclaw berry-run.  FruitClaw runs the VM on a Berry-sized worker
+		stack and wraps execution with the FruitClaw watchdog guard so a
