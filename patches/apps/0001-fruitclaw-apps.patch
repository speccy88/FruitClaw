+#include "berry.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#define be_malloc(vm, size)         be_realloc((vm), NULL, 0, (size))
+#define be_free(vm, ptr, size)      be_realloc((vm), (ptr), (size), 0)
+
+BERRY_API void* be_os_malloc(size_t size);
