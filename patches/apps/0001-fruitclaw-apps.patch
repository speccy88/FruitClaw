+/****************************************************************************
+ * Name: vi_checknotdir
+ *
+ * Description:
+ *   Check that the path is not a directory.  Missing files are valid editor
+ *   targets and should be left for fopen(..., "w") to create.
+ *
+ ****************************************************************************/
+
+static bool vi_checknotdir(FAR struct vi_s *vi, FAR const char *filename)
+{
+  FAR DIR *dir;
+
+  viinfo("filename=\"%s\"\n", filename);
+
+  dir = opendir(filename);
+  if (dir != NULL)
+    {
+      closedir(dir);
+      vi_error(vi, g_fmtnotfile, filename);
+      return false;
+    }
+
+  return true;
+}
