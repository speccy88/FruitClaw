+                  CONFIG_SYSTEM_TELNETD_PID_PATH, ret);
+        }
+
+      ret = telnetd_daemon(&config);
+      unlink(CONFIG_SYSTEM_TELNETD_PID_PATH);
+      return ret;
+    }
+
