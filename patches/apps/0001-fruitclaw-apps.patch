+  if (snprintf(path, sizeof(path), "%s/%s", CONFIG_FRUITCLAW_DATA_DIR,
+               CONFIG_FRUITCLAW_WIFI_CONFIG_LEAF) < (int)sizeof(path) &&
+      wifi_path_present(path))
