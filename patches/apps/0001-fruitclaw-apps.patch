+#ifndef BE_CONSTOBJ_H
+#define BE_CONSTOBJ_H
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#include "be_object.h"
+#include "be_gc.h"
+#include "be_map.h"
+#include "be_list.h"
+#include "be_class.h"
+#include "be_string.h"
