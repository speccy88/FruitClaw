+static bool fc_script_leaf_ok(const char *leaf)
+{
+  const char *p;
+  size_t len;
+
+  if (leaf == NULL || leaf[0] == '\0' || leaf[0] == '.' ||
+      strchr(leaf, '/') != NULL || strchr(leaf, '\\') != NULL ||
+      strstr(leaf, "..") != NULL)
+    {
+      return false;
+    }
+
+  len = strlen(leaf);
+  if (len == 0 || len > FC_SCRIPT_NAME_MAX)
+    {
+      return false;
+    }
+
+  for (p = leaf; *p != '\0'; p++)
+    {
+      if (!isalnum((unsigned char)*p) && *p != '_' && *p != '-' &&
+          *p != '.')
+        {
+          return false;
+        }
+    }
+
+  return true;
+}
