+      off += r;
+    }
+
+  pstate->ht_body[pstate->ht_content_length] = '\0';
+  pstate->ht_bodylen = pstate->ht_content_length;
+  return 0;
+#else
+  (void)pstate;
+  (void)buffered;
+  return 0;
+#endif
+}
