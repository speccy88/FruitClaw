+bstring* be_num2str(bvm *vm, bvalue *v)
+{
+    char buf[25];
+    if (var_isint(v)) {
+        snprintf(buf, sizeof(buf),BE_INT_FORMAT, var_toint(v));
+    } else if (var_isreal(v)) {
+        snprintf(buf, sizeof(buf), "%g", var_toreal(v));
