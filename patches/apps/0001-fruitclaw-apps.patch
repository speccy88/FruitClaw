+    }
+
+  if (mode == NULL || mode[0] == '\0' || strcmp(mode, "run") == 0)
+    {
+      *out = FC_SCRIPT_VALIDATION_RUN;
+      return 0;
+    }
+
+  if (strcmp(mode, "syntax") == 0)
+    {
+      *out = FC_SCRIPT_VALIDATION_SYNTAX;
+      return 0;
+    }
+
+  return -EINVAL;
