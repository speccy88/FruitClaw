+static int send_all(int sockfd, FAR const char *buf, int len)
+{
+  int remaining = len;
+  int ret;
+
+  while (remaining > 0)
+    {
+      ret = send(sockfd, buf, remaining, 0);
+      if (ret < 0 && errno == EINTR)
+        {
+          continue;
+        }
+
+      if (ret <= 0)
+        {
+          return ERROR;
+        }
+
+      buf += ret;
+      remaining -= ret;
+    }
+
+  return OK;
+}
