+/****************************************************************************
+ * Name: ftpd_setnonblocking
+ ****************************************************************************/
+
+static int ftpd_setnonblocking(int sd)
+{
+  int flags;
+
+  flags = fcntl(sd, F_GETFL, 0);
+  if (flags < 0 || fcntl(sd, F_SETFL, flags | O_NONBLOCK) < 0)
+    {
+      return -errno;
+    }
+
+  return OK;
 }
 
