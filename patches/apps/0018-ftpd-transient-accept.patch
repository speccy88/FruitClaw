-  return acceptsd;
+  if (timeout > 0)
+    {
+      if (clock_gettime(CLOCK_MONOTONIC, &now) < 0)
+        {
+          return -errno;
+        }
+
+      remaining = deadline -
+                  ((int64_t)now.tv_sec * 1000 + now.tv_nsec / 1000000);
+      if (remaining <= 0)
+        {
+          return -ETIMEDOUT;
+        }
+
+      if (remaining < delay_ms)
+        {
+          delay_ms = (int)remaining;
+        }
+    }
+
+  /* Keep board transports and watchdog hooks alive while avoiding a hot
+   * socket retry loop.  nanosleep() resumes its unelapsed delay after EINTR
+   * so an interrupt storm cannot turn this into a busy spin.
+   */
+
+  ftpd_activity_hook("rxpoll-wait");
+  delay.tv_sec  = 0;
+  delay.tv_nsec = delay_ms * 1000000L;
