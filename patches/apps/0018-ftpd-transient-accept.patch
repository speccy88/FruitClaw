+static int ftpd_retry_wait(int timeout, int64_t deadline)
+{
+  struct timespec delay;
+  struct timespec now;
+  int64_t remaining;
+  int delay_ms = FTPD_ACCEPT_RETRY_DELAY_MS;
+
+  if (timeout == 0)
