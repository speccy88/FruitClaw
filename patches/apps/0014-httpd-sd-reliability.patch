+static int httpd_hexvalue(char ch)
+{
+  if (ch >= '0' && ch <= '9')
+    {
+      return ch - '0';
+    }
+
+  if (ch >= 'a' && ch <= 'f')
+    {
+      return ch - 'a' + 10;
+    }
+
+  if (ch >= 'A' && ch <= 'F')
+    {
+      return ch - 'A' + 10;
+    }
+
+  return ERROR;
+}
+
+static bool httpd_normalize_path(char *path)
+{
+  char *segment;
+  char *cursor;
+  char *src;
+  char *dst;
+
+  if (path == NULL || path[0] != '/')
+    {
+      return false;
+    }
+
+  cursor = strchr(path, '?');
+  if (cursor != NULL)
+    {
+      *cursor = '\0';
+    }
+
+  src = path;
+  dst = path;
+  while (*src != '\0')
+    {
+      unsigned char ch = (unsigned char)*src++;
+
+      if (ch == '%')
+        {
+          int high;
+          int low;
+
+          if (src[0] == '\0' || src[1] == '\0')
+            {
+              return false;
+            }
+
+          high = httpd_hexvalue(src[0]);
+          low = httpd_hexvalue(src[1]);
+
+          if (high < 0 || low < 0)
+            {
+              return false;
+            }
+
+          ch = (high << 4) | low;
+          src += 2;
+
+          /* Encoded separators are rejected rather than normalized so that
+           * every backend sees the same unambiguous path hierarchy.
+           */
+
+          if (ch == '/' || ch == '\\')
+            {
+              return false;
+            }
+        }
+
+      if (ch == '\0' || ch == '\\' || ch < ' ' || ch == 0x7f)
+        {
+          return false;
+        }
+
+      *dst++ = ch;
+    }
+
+  *dst = '\0';
+
+  segment = path + 1;
+  for (cursor = segment; ; cursor++)
+    {
+      size_t len;
+
+      if (*cursor != '/' && *cursor != '\0')
+        {
+          continue;
+        }
+
+      len = cursor - segment;
+      if ((len == 1 && segment[0] == '.') ||
+          (len == 2 && segment[0] == '.' && segment[1] == '.'))
+        {
+          return false;
+        }
+
+      if (*cursor == '\0')
+        {
+          return true;
+        }
+
+      segment = cursor + 1;
+    }
+}
