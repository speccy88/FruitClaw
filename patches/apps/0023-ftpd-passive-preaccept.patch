 /****************************************************************************
+ * Name: ftpd_datapending
+ ****************************************************************************/
+
+static bool ftpd_datapending(FAR struct ftpd_session_s *session)
+{
+  bool pending;
+
+  pthread_mutex_lock(&session->lock);
+  pending = !session->shutdown && session->data.sd >= 0 &&
+            !session->dataaccepted;
+  pthread_mutex_unlock(&session->lock);
+  return pending;
+}
+
+/****************************************************************************
+ * Name: ftpd_datapreaccept
+ ****************************************************************************/
+
+static int ftpd_datapreaccept(FAR struct ftpd_session_s *session,
+                              int listensd)
+{
+  union ftpd_sockaddr_u addr;
+  socklen_t addrlen = sizeof(addr);
+#ifdef CONFIG_NET_SOLINGER
+  struct linger ling;
+#endif
+  bool accepted = false;
+  int acceptsd = -1;
+  int ret;
+
+  pthread_mutex_lock(&session->lock);
+  if (session->shutdown)
+    {
+      ret = -ESHUTDOWN;
+    }
+  else if (session->data.sd != listensd || session->dataaccepted)
+    {
+      ret = OK;
+    }
+  else
+    {
+      acceptsd = accept4(listensd, (FAR struct sockaddr *)&addr,
+                         &addrlen, SOCK_CLOEXEC);
+      if (acceptsd < 0)
+        {
+          ret = -errno;
+        }
+      else if (!ftpd_datahost_matches(session, &addr))
+        {
+          ret = -EPERM;
+        }
+      else
+        {
+          session->data.sd       = acceptsd;
+          session->data.addr     = addr;
+          session->data.addrlen  = addrlen;
+          session->dataaccepted  = true;
+          accepted               = true;
+          ret = OK;
+        }
+    }
+
+  pthread_mutex_unlock(&session->lock);
+  if (!accepted)
+    {
+      if (acceptsd >= 0)
+        {
+          close(acceptsd);
+        }
+
+      return ret;
+    }
+
+  close(listensd);
+
+#ifdef CONFIG_NET_SOLINGER
+  memset(&ling, 0, sizeof(ling));
+  ling.l_onoff  = 1;
+  ling.l_linger = 4;
+  setsockopt(acceptsd, SOL_SOCKET, SO_LINGER, &ling, sizeof(ling));
+#endif
+
+  return OK;
+}
+
