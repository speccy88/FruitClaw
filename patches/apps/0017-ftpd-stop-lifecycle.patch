+/****************************************************************************
+ * Name: ftpd_serveraccept
+ ****************************************************************************/
+
+static int ftpd_serveraccept(FAR struct ftpd_server_s *server,
+                             FAR void *addr, FAR socklen_t *addrlen,
+                             int timeout)
+{
+  int remaining = timeout;
+  int acceptsd;
+  int slice;
+  int sd;
+  int ret;
+
+  for (; ; )
+    {
+      pthread_mutex_lock(&server->lock);
+      if (server->shutdown || server->sd < 0)
+        {
+          pthread_mutex_unlock(&server->lock);
+          return -ESHUTDOWN;
+        }
+
+      sd = server->sd;
+      pthread_mutex_unlock(&server->lock);
+
+      if (remaining < 0 || remaining > FTPD_SHUTDOWN_POLL_INTERVAL_MS)
+        {
+          slice = FTPD_SHUTDOWN_POLL_INTERVAL_MS;
+        }
+      else
+        {
+          slice = remaining;
+        }
+
+      ret = ftpd_rxpoll(sd, slice);
+      if (ret == -ETIMEDOUT)
+        {
+          if (timeout == 0)
+            {
+              return ret;
+            }
+
+          if (remaining > 0)
+            {
+              remaining -= slice;
+              if (remaining <= 0)
+                {
+                  return ret;
+                }
+            }
+
+          continue;
+        }
+      else if (ret < 0)
+        {
+          return ret;
+        }
+
+      /* Serialize the shutdown check and accept.  The listen socket is
+       * non-blocking, so this lock cannot be held across an indefinite
+       * accept if another caller consumed the pending connection.
+       */
+
+      pthread_mutex_lock(&server->lock);
+      if (server->shutdown || server->sd != sd)
+        {
+          pthread_mutex_unlock(&server->lock);
+          return -ESHUTDOWN;
+        }
+
+      acceptsd = accept4(sd, (FAR struct sockaddr *)addr, addrlen,
+                         SOCK_CLOEXEC);
+      if (acceptsd < 0)
+        {
+          ret = -errno;
+          pthread_mutex_unlock(&server->lock);
+          return ret;
+        }
+
+      pthread_mutex_unlock(&server->lock);
+      return acceptsd;
+    }
+}
+
+/****************************************************************************
+ * Name: ftpd_dataaccept
+ ****************************************************************************/
+
+static int ftpd_dataaccept(FAR struct ftpd_session_s *session, int sd,
+                           FAR void *addr, FAR socklen_t *addrlen,
+                           int timeout)
+{
+  int remaining = timeout;
+  int slice;
+  int ret;
+
+  for (; ; )
+    {
+      pthread_mutex_lock(&session->lock);
+      if (session->shutdown)
+        {
+          pthread_mutex_unlock(&session->lock);
+          return -ESHUTDOWN;
+        }
+
+      pthread_mutex_unlock(&session->lock);
+
+      if (remaining < 0 || remaining > FTPD_SHUTDOWN_POLL_INTERVAL_MS)
+        {
+          slice = FTPD_SHUTDOWN_POLL_INTERVAL_MS;
+        }
+      else
+        {
+          slice = remaining;
+        }
+
+      ret = ftpd_accept(sd, addr, addrlen, slice);
+      if (ret != -ETIMEDOUT)
+        {
+          return ret;
+        }
+
+      if (timeout == 0)
+        {
+          return ret;
+        }
+
+      if (remaining > 0)
+        {
+          remaining -= slice;
+          if (remaining <= 0)
+            {
+              return ret;
+            }
+        }
+    }
+}
