+/****************************************************************************
+ * Name: ftpd_shutdown
+ *
+ * Description:
+ *   Stop accepting new FTP connections and request all active worker
+ *   sessions to exit.  The handle remains valid until ftpd_close() returns.
+ *   This function is idempotent and may be called from a thread other than
+ *   the one blocked in ftpd_session().
+ *
+ * Input Parameters:
+ *   handle - A handle previously returned by ftpd_open
+ *
+ * Returned Value:
+ *   Zero is returned on success.  A negated errno value is returned on
+ *   failure.
+ *
+ ****************************************************************************/
+
+int ftpd_shutdown(FTPD_SESSION handle);
+
