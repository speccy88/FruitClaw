+/****************************************************************************
+ * Name: ftpd_account_clone
+ ****************************************************************************/
+
+static int ftpd_account_clone(FAR const struct ftpd_account_s *account,
+                              FAR struct ftpd_account_s **clone)
+{
+  FAR struct ftpd_account_s *head = NULL;
+  FAR struct ftpd_account_s *tail = NULL;
+  FAR struct ftpd_account_s *newaccount;
+  int ret;
+
+  DEBUGASSERT(clone != NULL);
+  *clone = NULL;
+
+  while (account != NULL)
+    {
+      newaccount = ftpd_account_new(account->user, account->flags);
+      if (newaccount == NULL)
+        {
+          ret = -ENOMEM;
+          goto errout;
+        }
+
+      ret = ftpd_account_setpassword(newaccount, account->password);
+      if (ret < 0)
+        {
+          ftpd_account_free(newaccount);
+          goto errout;
+        }
+
+      ret = ftpd_account_sethome(newaccount, account->home);
+      if (ret < 0)
+        {
+          ftpd_account_free(newaccount);
+          goto errout;
+        }
+
+      newaccount->blink = tail;
+      if (tail == NULL)
+        {
+          head = newaccount;
+        }
+      else
+        {
+          tail->flink = newaccount;
+        }
+
+      tail = newaccount;
+      account = account->flink;
+    }
+
+  *clone = head;
+  return OK;
+
+errout:
+  if (head != NULL)
+    {
+      ftpd_account_free(head);
+    }
+
+  return ret;
+}
