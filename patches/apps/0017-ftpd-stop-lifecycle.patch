+/****************************************************************************
+ * Name: ftpd_dataassign
+ ****************************************************************************/
+
+static int ftpd_dataassign(FAR struct ftpd_session_s *session, int sd)
+{
+  int ret = OK;
+
+  DEBUGASSERT(sd >= 0);
+
+  pthread_mutex_lock(&session->lock);
+  if (session->shutdown)
+    {
+      ret = -ESHUTDOWN;
+    }
+  else if (session->data.sd >= 0)
+    {
+      ret = -EBUSY;
+    }
+  else
+    {
+      session->data.sd = sd;
+    }
+
+  pthread_mutex_unlock(&session->lock);
+
+  if (ret < 0)
+    {
+      close(sd);
+    }
+
+  return ret;
+}
