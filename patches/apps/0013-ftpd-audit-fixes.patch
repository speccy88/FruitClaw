+/****************************************************************************
+ * Name: ftpd_connect
+ ****************************************************************************/
+
+static int ftpd_connect(int sd, FAR const struct sockaddr *addr,
+                        socklen_t addrlen, int timeout)
+{
+  socklen_t errlen;
+  int oldflags;
+  int errcode;
+  int ret;
+
+  if (timeout < 0)
+    {
+      ftpd_activity_hook("connect");
+      ret = connect(sd, addr, addrlen);
+      if (ret < 0)
+        {
+          return -errno;
+        }
+
+      return OK;
+    }
+
+  oldflags = fcntl(sd, F_GETFL, 0);
+  if (oldflags < 0 || fcntl(sd, F_SETFL, oldflags | O_NONBLOCK) < 0)
+    {
+      return -errno;
+    }
+
+  ftpd_activity_hook("connect");
+  ret = connect(sd, addr, addrlen);
+  if (ret < 0)
+    {
+      errcode = errno;
+      if (errcode != EINPROGRESS && errcode != EALREADY)
+        {
+          ret = -errcode;
+          goto out;
+        }
+
+      ret = ftpd_txpoll(sd, timeout);
+      if (ret < 0)
+        {
+          goto out;
+        }
+
+      errlen = sizeof(errcode);
+      if (getsockopt(sd, SOL_SOCKET, SO_ERROR, &errcode, &errlen) < 0)
+        {
+          ret = -errno;
+          goto out;
+        }
+
+      ret = errcode == 0 ? OK : -errcode;
+    }
+
+out:
+  if (fcntl(sd, F_SETFL, oldflags) < 0 && ret >= 0)
+    {
+      ret = -errno;
+    }
+
+  return ret;
 }
 
