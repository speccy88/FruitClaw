+/****************************************************************************
+ * Name: ftpd_datahost_matches
+ ****************************************************************************/
+
+static bool ftpd_datahost_matches(FAR struct ftpd_session_s *session,
+                                  FAR const union ftpd_sockaddr_u *addr)
+{
+  FAR const union ftpd_sockaddr_u *peer = &session->cmd.addr;
+
+#ifdef CONFIG_NET_IPv4
+  if (peer->ss.ss_family == AF_INET && addr->ss.ss_family == AF_INET)
+    {
+      return peer->in4.sin_addr.s_addr == addr->in4.sin_addr.s_addr;
+    }
+#endif
+
+#ifdef CONFIG_NET_IPv6
+  if (peer->ss.ss_family == AF_INET6 && addr->ss.ss_family == AF_INET6)
+    {
+      return memcmp(&peer->in6.sin6_addr, &addr->in6.sin6_addr,
+                    sizeof(peer->in6.sin6_addr)) == 0;
+    }
+#endif
+
+  return false;
 }
 
