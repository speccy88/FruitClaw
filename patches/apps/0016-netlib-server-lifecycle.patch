diff --git a/netutils/netlib/netlib_server.c b/netutils/netlib/netlib_server.c
--- a/netutils/netlib/netlib_server.c
+++ b/netutils/netlib/netlib_server.c
@@ -98,7 +98,17 @@ void netlib_server(uint16_t portno,
