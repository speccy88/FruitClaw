+static ssize_t httpd_recv_retry(int sockfd, FAR void *buf, size_t len,
+                                FAR const char *wait_phase)
+{
+  unsigned int retries = 0;
+  int oldflags;
+  bool restore_flags = false;
+
+  oldflags = fcntl(sockfd, F_GETFL, 0);
+  if (oldflags >= 0 && (oldflags & O_NONBLOCK) == 0)
+    {
+      if (fcntl(sockfd, F_SETFL, oldflags | O_NONBLOCK) >= 0)
+        {
+          restore_flags = true;
+        }
+      else
+        {
