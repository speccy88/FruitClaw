+static int httpd_send_retry(int sockfd, FAR const void *buf, size_t len)
+{
+  FAR const uint8_t *ptr = (FAR const uint8_t *)buf;
+  size_t off = 0;
+  unsigned int retries = 0;
+  int oldflags;
+  bool restore_flags = false;
+#ifdef CONFIG_NET_SOCKOPTS
+  struct timeval old_sndtimeo;
+  socklen_t old_sndtimeo_len = sizeof(old_sndtimeo);
+  bool restore_sndtimeo = false;
+#endif
+
+  if (len == 0)
+    {
+      return 0;
+    }
+
+  oldflags = fcntl(sockfd, F_GETFL, 0);
+  if (oldflags >= 0 && (oldflags & O_NONBLOCK) == 0)
+    {
+      if (fcntl(sockfd, F_SETFL, oldflags | O_NONBLOCK) >= 0)
+        {
+          restore_flags = true;
+        }
+      else
+        {
+          httpd_activity_hook("send-nonblock-fail");
+        }
+    }
+  else if (oldflags < 0)
+    {
+      httpd_activity_hook("send-nonblock-fail");
+    }
+
+#ifdef CONFIG_NET_SOCKOPTS
+  if (getsockopt(sockfd, SOL_SOCKET, SO_SNDTIMEO, &old_sndtimeo,
+                 &old_sndtimeo_len) >= 0 &&
+      old_sndtimeo_len == sizeof(old_sndtimeo))
+    {
+      struct timeval sndtimeo;
+
+      sndtimeo.tv_sec = HTTPD_SEND_TIMEOUT_MS / 1000;
+      sndtimeo.tv_usec = (HTTPD_SEND_TIMEOUT_MS % 1000) * 1000;
+      if (setsockopt(sockfd, SOL_SOCKET, SO_SNDTIMEO, &sndtimeo,
+                     sizeof(sndtimeo)) >= 0)
+        {
+          restore_sndtimeo = true;
+        }
+      else
+        {
+          httpd_activity_hook("send-timeout-fail");
+        }
+    }
+#endif
+
+  while (off < len)
+    {
+      size_t chunk = len - off;
+      ssize_t ret;
+
+      if (chunk > HTTPD_SEND_CHUNK_MAX)
+        {
+          chunk = HTTPD_SEND_CHUNK_MAX;
+        }
+
+      httpd_activity_hook("send-call");
+      ret = send(sockfd, ptr + off, chunk, HTTPD_SEND_FLAGS);
+      if (ret > 0)
+        {
+          off += ret;
+          retries = 0;
+          httpd_activity_hook("send-progress");
+          continue;
+        }
+
+      if (ret < 0 &&
+          (errno == EAGAIN || errno == EWOULDBLOCK || errno == EINTR))
+        {
+          if (retries++ < HTTPD_SEND_RETRY_MAX)
+            {
+              struct pollfd pfd;
+
+              httpd_activity_hook(errno == EINTR ? "send-eintr" :
+                                                  "send-wait");
+              pfd.fd = sockfd;
+              pfd.events = POLLOUT;
+              pfd.revents = 0;
+              (void)poll(&pfd, 1, HTTPD_SEND_POLL_MS);
+              continue;
+            }
+
+          errno = ETIMEDOUT;
+        }
+      else if (ret == 0)
+        {
+          errno = EPIPE;
+        }
+
+      if (restore_flags)
+        {
+          (void)fcntl(sockfd, F_SETFL, oldflags);
+        }
+
+#ifdef CONFIG_NET_SOCKOPTS
+      if (restore_sndtimeo)
+        {
+          (void)setsockopt(sockfd, SOL_SOCKET, SO_SNDTIMEO, &old_sndtimeo,
+                           sizeof(old_sndtimeo));
+        }
+#endif
+
+      return ERROR;
+    }
+
+  if (restore_flags)
+    {
+      (void)fcntl(sockfd, F_SETFL, oldflags);
+    }
+
+#ifdef CONFIG_NET_SOCKOPTS
+  if (restore_sndtimeo)
+    {
+      (void)setsockopt(sockfd, SOL_SOCKET, SO_SNDTIMEO, &old_sndtimeo,
+                       sizeof(old_sndtimeo));
+    }
+#endif
+
+  return (int)len;
+}
