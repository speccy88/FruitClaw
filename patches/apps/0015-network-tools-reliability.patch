+          offset += written;
+        }
+      else if (written < 0 && errno == EINTR)
+        {
+          continue;
+        }
+      else
+        {
+          if (written == 0)
+            {
+              errno = EIO;
+            }
+
+          return ERROR;
+        }
+    }
+
+  return OK;
