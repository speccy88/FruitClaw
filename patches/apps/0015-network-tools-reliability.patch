+/****************************************************************************
+ * Name: take_skip_lf_after_cr
+ *
+ * Description:
+ *   Return and clear the CR suffix state for one readline caller.  NSH can
+ *   have a USB console and several Telnet sessions in readline concurrently,
+ *   so this state must not be process-global.
+ ****************************************************************************/
+
+static bool take_skip_lf_after_cr(pid_t tid)
+{
+  bool skip = false;
+  int i;
+
+  readline_lock();
+  for (i = 0; i < RL_SESSION_STATE_SLOTS; i++)
+    {
+      if (g_session_state[i].used && g_session_state[i].tid == tid)
+        {
+          skip = g_session_state[i].skip_lf_after_cr;
+          g_session_state[i].skip_lf_after_cr = false;
+          break;
+        }
+    }
+
+  readline_unlock();
+  return skip;
+}
+
+/****************************************************************************
+ * Name: set_skip_lf_after_cr
+ ****************************************************************************/
+
+static void set_skip_lf_after_cr(pid_t tid, bool skip)
+{
+  FAR struct rl_session_state_s *state = NULL;
+  FAR struct rl_session_state_s *reusable = NULL;
+  int i;
+
+  readline_lock();
+  for (i = 0; i < RL_SESSION_STATE_SLOTS; i++)
+    {
+      if (g_session_state[i].used && g_session_state[i].tid == tid)
+        {
+          state = &g_session_state[i];
+          break;
+        }
+
+      if (!g_session_state[i].used)
+        {
+          if (reusable == NULL)
+            {
+              reusable = &g_session_state[i];
+            }
+        }
+      else if (!g_session_state[i].skip_lf_after_cr)
+        {
+          reusable = &g_session_state[i];
+        }
+    }
+
+  if (state == NULL && skip)
+    {
+      state = reusable != NULL ? reusable :
+              &g_session_state[(unsigned int)tid % RL_SESSION_STATE_SLOTS];
+      state->used = true;
+      state->tid  = tid;
+    }
+
+  if (state != NULL)
+    {
+      state->skip_lf_after_cr = skip;
+    }
+
+  readline_unlock();
+}
+
